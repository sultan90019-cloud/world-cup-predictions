# ============================================
# World Cup Predictions - إعدادات المشروع
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم

# ----- قاعدة البيانات -----
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# ----- الأمان (مطلوب) -----
# غيّر هذا إلى كلمة سر عشوائية قوية
# يمكنك توليد واحدة باستخدام: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-random-secret-at-least-32-chars

# ----- حساب المدير (يُستخدم عند التشغيل الأول فقط) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# ----- الخادم -----
PORT=3000

# ----- البيئة -----
# NODE_ENV=production  # فعّل HTTPS للتطبيق المباشر