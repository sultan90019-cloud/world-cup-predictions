<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>تسجيل الدخول - مسابقة توقعات كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="auth-page">
  <div class="auth-backdrop"></div>
  <div class="auth-container">
    <div class="auth-logo-wrapper">
      <img src="/logo.png" alt="شعار مسابقة توقعات كأس العالم 2026" class="auth-logo">
    </div>
    <div class="card auth-card">
      <h2 class="auth-title">تسجيل الدخول</h2>
      <p class="auth-subtitle">ادخل حسابك للمشاركة في المسابقة</p>
      <% if (message) { %>
        <div class="message auth-message"><%= message %></div>
      <% } %>
      <form method="POST" action="/login" class="form-grid">
        <label>اسم المستخدم
          <input type="text" name="username" placeholder="اسم المستخدم" required>
        </label>
        <label>كلمة المرور
          <input type="password" name="password" placeholder="كلمة المرور" required>
        </label>
        <input type="submit" value="دخول" class="auth-submit">
      </form>
      <p class="auth-switch">ليس لديك حساب؟ <a href="/register">سجل هنا</a></p>
    </div>
  </div>
</body>
</html>