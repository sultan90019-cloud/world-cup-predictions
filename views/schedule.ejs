<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>جدول المباريات - كأس العالم 2026</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'schedule', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

        <!-- ===== MOBILE SCHEDULE (≤860px) ===== -->
        <div class="ms">

          <!-- Hero Header -->
          <div class="ms2-header">
            <div class="ms2-header-bg"></div>
            <div class="ms2-header-top">
              <div style="width:40px;"></div>
              <div class="ms2-header-center">
                <img src="/logo.png" alt="شعار" class="ms2-logo">
              </div>
              <div style="width:40px;"></div>
            </div>
            <div class="ms2-header-titles">
              <h1 class="ms2-title">المباريات</h1>
              <p class="ms2-sub">جميع مباريات كأس العالم 2026</p>
            </div>

            <!-- Main Filters (tabs) -->
            <div class="ms2-tabs-wrap">
              <div class="ms2-tabs" id="msTabs">
                <button class="ms2-tab active" data-filter="all" onclick="msFilter('all',this)">جميع المباريات</button>
                <button class="ms2-tab" data-filter="upcoming" onclick="msFilter('upcoming',this)">المباريات القادمة</button>
                <button class="ms2-tab" data-filter="finished" onclick="msFilter('finished',this)">انتهت</button>
              </div>
            </div>
          </div>

          <!-- Group Filters (pills) -->
          <div class="ms2-group-wrap">
            <div class="ms2-group-scroll" id="msGroupFilters">
              <button class="ms2-gpill active" data-group="all" onclick="msGroupFilter('all',this)">جميع المجموعات</button>
              <% var allGroups = ['المجموعة A','المجموعة B','المجموعة C','المجموعة D','المجموعة E','المجموعة F','المجموعة G','المجموعة H','المجموعة I','المجموعة J','المجموعة K','المجموعة L']; %>
              <% allGroups.forEach(function(g){ %>
              <button class="ms2-gpill" data-group="<%= g %>" onclick="msGroupFilter('<%= g %>',this)"><%= g %></button>
              <% }); %>
            </div>
          </div>

          <!-- Match Cards -->
          <div class="ms-list" id="msMatchList">
            <% if (matches.length === 0) { %>
            <div class="ms-empty">
              <span class="ms-empty-icon">⚽</span>
              <p>لا توجد مباريات منشورة حالياً</p>
            </div>
            <% } else { %>
              <% matches.forEach(function(match, idx) { %>
                <%
                  var ended = match.actual_scoreA != null;
                  var locked = match.locked;
                  var isUpcoming = !ended && new Date(match.start_at) > Date.now();
                  var isOpen = !ended && !locked;
                  var group = match.stage || '';
                  var cardCls = 'ms-card';
                  if (ended) cardCls += ' ms-ended';
                  if (isOpen) cardCls += ' ms-open';
                  if (locked && !ended) cardCls += ' ms-locked';
                %>
                <div class="<%= cardCls %>" data-ms-filter="<%= ended ? 'finished' : isUpcoming ? 'upcoming' : 'open' %>" data-ms-group="<%= group %>" data-ms-idx="<%= idx %>">
                  <div class="ms-card-badge <%= ended ? 'ms-badge-ended' : locked ? 'ms-badge-locked' : 'ms-badge-upcoming' %>">
                    <%= ended ? 'انتهت' : locked ? 'أغلقت التوقعات' : group + ' - الجولة ' + match.round %>
                  </div>
                  <div class="ms-card-teams">
                    <div class="ms-card-team">
                      <img src="/flags/<%= teamFlags[match.teamA] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'" class="ms-card-flag">
                      <span class="ms-card-name"><%= match.teamA %></span>
                    </div>
                    <div class="ms-card-vs">
                      <% if (ended) { %>
                      <span class="ms-card-score"><%= match.actual_scoreA %> - <%= match.actual_scoreB %></span>
                      <% } else { %>
                      <span class="ms-card-vs-text">VS</span>
                      <% } %>
                    </div>
                    <div class="ms-card-team">
                      <img src="/flags/<%= teamFlags[match.teamB] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'" class="ms-card-flag">
                      <span class="ms-card-name"><%= match.teamB %></span>
                    </div>
                  </div>
                  <div class="ms-card-info">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span><%= new Date(match.start_at).toLocaleTimeString('ar-EG', { hour:'2-digit', minute:'2-digit', timeZone:'Asia/Riyadh' }) %></span>
                    <span class="ms-info-dot"></span>
                    <span><%= new Date(match.start_at).toLocaleDateString('ar-SA', { weekday:'long', month:'long', day:'numeric', timeZone:'Asia/Riyadh' }) %></span>
                  </div>
                  <div class="ms-card-action">
                    <% if (ended) { %>
                      <span class="ms-card-ended">انتهت · <%= match.actual_scoreA %>-<%= match.actual_scoreB %></span>
                    <% } else if (locked) { %>
                      <span class="ms-card-locked-txt">التوقع مغلق</span>
                    <% } else { %>
                      <a href="/predictions" class="ms-card-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        أضف توقعك
                      </a>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <!-- Show More -->
          <div class="ms-show-more" id="msShowMore" style="display:none;">
            <button onclick="msLoadMore()">
              عرض المزيد من المباريات
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>

        </div>
        <!-- ===== END MOBILE SCHEDULE ===== -->

        <!-- ===== DESKTOP SCHEDULE (≥861px) ===== -->
        <div class="ms-desktop">

        <!-- Hero Header -->
        <div class="sc-hero">
          <div class="sc-hero-bg"></div>
          <div class="sc-hero-content">
            <div class="sc-hero-right">
              <img src="/logo.png" alt="شعار" class="sc-hero-logo">
            </div>
            <div class="sc-hero-center">
              <span class="sc-hero-badge">كأس العالم 2026</span>
              <h1 class="sc-hero-title">جدول المباريات</h1>
              <div class="sc-hero-date">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                الخميس، 11 يونيو 2026
              </div>
            </div>
            <div class="sc-hero-left">
              <div class="sc-countdown-label">العد التنازلي للانطلاق البطولة</div>
              <div class="sc-countdown">
                <div class="sc-cd-box"><span class="sc-cd-num" id="cd-d">07</span><span class="sc-cd-lbl">أيام</span></div>
                <div class="sc-cd-sep">:</div>
                <div class="sc-cd-box"><span class="sc-cd-num" id="cd-h">18</span><span class="sc-cd-lbl">ساعة</span></div>
                <div class="sc-cd-sep">:</div>
                <div class="sc-cd-box"><span class="sc-cd-num" id="cd-m">24</span><span class="sc-cd-lbl">دقيقة</span></div>
                <div class="sc-cd-sep">:</div>
                <div class="sc-cd-box"><span class="sc-cd-num" id="cd-s">56</span><span class="sc-cd-lbl">ثانية</span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats Bar -->
        <div class="sc-stats">
          <div class="sc-stat-card">
            <div class="sc-stat-icon sc-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            </div>
            <div class="sc-stat-info">
              <span class="sc-stat-num"><%= totalPlayers.toLocaleString('ar-EG') %></span>
              <span class="sc-stat-lbl">عدد المشاركين</span>
            </div>
          </div>
          <div class="sc-stat-card">
            <div class="sc-stat-icon sc-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
            </div>
            <div class="sc-stat-info">
              <span class="sc-stat-num"><%= predictionsCount.toLocaleString('ar-EG') %></span>
              <span class="sc-stat-lbl">التوقعات المسجلة</span>
            </div>
          </div>
          <div class="sc-stat-card">
            <div class="sc-stat-icon sc-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <div class="sc-stat-info">
              <span class="sc-stat-num"><%= allMatchesCount %></span>
              <span class="sc-stat-lbl">عدد المباريات</span>
            </div>
          </div>
          <div class="sc-stat-card sc-stat-highlight">
            <div class="sc-stat-icon sc-stat-gold">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </div>
            <div class="sc-stat-info">
              <span class="sc-stat-num"><%= userRank > 0 ? userRank : '-' %></span>
              <span class="sc-stat-lbl">ترتيبك الحالي</span>
            </div>
          </div>
          <div class="sc-stat-card">
            <div class="sc-stat-icon sc-stat-green">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>
            <div class="sc-stat-info">
              <span class="sc-stat-num"><%= userPoints.toLocaleString('ar-EG') %></span>
              <span class="sc-stat-lbl">نقاطك</span>
            </div>
          </div>
        </div>

        <!-- Toolbar -->
        <div class="sc-toolbar">
          <div class="sc-toolbar-right">
            <span class="sc-toolbar-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              جميع المباريات
            </span>
          </div>
          <div class="sc-toolbar-left">
            <button class="sc-view-btn active" id="btn-list" onclick="setView('list')" title="عرض القائمة">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </button>
            <button class="sc-view-btn" id="btn-grid" onclick="setView('grid')" title="عرض الشبكة">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </button>
            <div class="sc-filter-wrap">
              <button class="sc-filter-btn" onclick="toggleFilters()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                تصفيه المباريات
              </button>
            </div>
          </div>
        </div>

        <!-- Filter Panel -->
        <div class="sc-filters" id="filter-panel" style="display:none;">
          <button class="sc-filter-pill active" onclick="filterRound('all', this)">الكل</button>
          <button class="sc-filter-pill" onclick="filterRound(1, this)">الجولة الأولى</button>
          <button class="sc-filter-pill" onclick="filterRound(2, this)">الجولة الثانية</button>
          <button class="sc-filter-pill" onclick="filterRound(3, this)">الجولة الثالثة</button>
        </div>

        <!-- Matches List -->
        <%
          const byDate = {};
          matches.forEach(match => {
            const d = new Date(match.start_at);
            const key = d.toLocaleDateString('ar-EG', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Asia/Riyadh' });
            if (!byDate[key]) byDate[key] = [];
            byDate[key].push(match);
          });
        %>

        <% if (matches.length === 0) { %>
          <div class="sc-empty">
            <div class="sc-empty-icon">⚽</div>
            <div class="sc-empty-title">لا توجد مباريات منشورة حالياً</div>
            <div class="sc-empty-text">سيتم نشر المباريات قريباً من إدارة المسابقة</div>
          </div>
        <% } else { %>
          <% var matchIndex = 0; %>
          <% Object.keys(byDate).forEach(date => { %>
            <div class="sc-date-group" data-round-filter>
              <div class="sc-date-header">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span><%= date %></span>
              </div>
              <div class="sc-matches-list">
                <% byDate[date].forEach(match => {
                  matchIndex++;
                  var statusCls = 'sc-status-open';
                  var statusTxt = 'متاحة';
                  if (match.actual_scoreA != null) { statusCls = 'sc-status-ended'; statusTxt = 'انتهت'; }
                  else if (match.locked) { statusCls = 'sc-status-locked'; statusTxt = 'مقفولة'; }
                %>
                <div class="sc-match-row" data-round="<%= match.round %>" data-idx="<%= matchIndex %>">
                  <button class="sc-star" title="أضف للمفضلة">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </button>
                  <div class="sc-team sc-team-b">
                    <span class="sc-team-name"><%= match.teamB %></span>
                    <img class="sc-flag" src="/flags/<%= teamFlags[match.teamB] || 'unknown' %>.png" alt="<%= match.teamB %>" onerror="this.src='/flags/unknown.png'" />
                  </div>
                  <div class="sc-match-meta">
                    <span class="sc-match-time">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <%= new Date(match.start_at).toLocaleString('ar-EG', { hour: '2-digit', minute: '2-digit' }) %>
                    </span>
                    <span class="sc-match-group"><%= match.stage %></span>
                  </div>
                  <div class="sc-vs-badge">
                    <% if (match.actual_scoreA != null) { %>
                      <span class="sc-final-score"><%= match.actual_scoreA %> - <%= match.actual_scoreB %></span>
                    <% } else { %>
                      VS
                    <% } %>
                  </div>
                  <div class="sc-team sc-team-a">
                    <img class="sc-flag" src="/flags/<%= teamFlags[match.teamA] || 'unknown' %>.png" alt="<%= match.teamA %>" onerror="this.src='/flags/unknown.png'" />
                    <span class="sc-team-name"><%= match.teamA %></span>
                  </div>
                  <div class="sc-match-action">
                    <% if (match.actual_scoreA == null && !match.locked) { %>
                      <a class="sc-status-btn <%= statusCls %>" href="/predictions"><%= statusTxt %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg></a>
                    <% } else { %>
                      <a class="sc-status-btn <%= statusCls %>" href="/predictions"><%= statusTxt %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg></a>
                    <% } %>
                  </div>
                </div>
                <% }) %>
              </div>
            </div>
          <% }) %>

          <div class="sc-show-more" id="show-more" style="display:none;">
            <button onclick="showMoreMatches()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
              عرض المزيد من المباريات
            </button>
          </div>
        <% } %>

    </div>
  </section>
    </main>
  </div>

  <script>
    // Countdown (desktop)
    (function(){
      var target = new Date('2026-06-11T19:00:00Z').getTime();
      function tick(){
        var diff = target - Date.now();
        if(diff<=0){ document.getElementById('cd-d').textContent='00'; document.getElementById('cd-h').textContent='00'; document.getElementById('cd-m').textContent='00'; document.getElementById('cd-s').textContent='00'; return; }
        var d=Math.floor(diff/864e5), h=Math.floor(diff%864e5/36e5), m=Math.floor(diff%36e5/6e4), s=Math.floor(diff%6e4/1e3);
        document.getElementById('cd-d').textContent=String(d).padStart(2,'0');
        document.getElementById('cd-h').textContent=String(h).padStart(2,'0');
        document.getElementById('cd-m').textContent=String(m).padStart(2,'0');
        document.getElementById('cd-s').textContent=String(s).padStart(2,'0');
      }
      tick(); setInterval(tick,1000);
    })();

    // Desktop: View Toggle, Filters, Show More
    function setView(v){
      document.getElementById('btn-list').classList.toggle('active',v==='list');
      document.getElementById('btn-grid').classList.toggle('active',v==='grid');
      document.querySelectorAll('.sc-matches-list').forEach(function(el){ el.className='sc-matches-list'+(v==='grid'?' sc-grid-view':''); });
    }
    function toggleFilters(){ var p=document.getElementById('filter-panel'); p.style.display=p.style.display==='none'?'flex':'none'; }
    function filterRound(r,btn){
      document.querySelectorAll('.sc-filter-pill').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');
      document.querySelectorAll('.sc-match-row').forEach(function(row){ row.style.display=(r==='all'||row.dataset.round==r)?'':'none'; });
      document.querySelectorAll('.sc-date-group').forEach(function(g){ var vis=g.querySelectorAll('.sc-match-row:not([style*=\"display: none\"])'); g.style.display=vis.length===0?'none':''; });
    }
    var visibleCount=8;
    (function initShowMore(){
      var rows=document.querySelectorAll('.sc-match-row');
      if(rows.length<=visibleCount) return;
      for(var i=visibleCount;i<rows.length;i++) rows[i].style.display='none';
      document.getElementById('show-more').style.display='flex';
    })();
    function showMoreMatches(){
      var rows=document.querySelectorAll('.sc-match-row');
      var end=Math.min(visibleCount+8,rows.length);
      for(var i=visibleCount;i<end;i++) rows[i].style.display='';
      visibleCount=end;
      if(visibleCount>=rows.length) document.getElementById('show-more').style.display='none';
    }

    // Mobile: Main Filter
    function msFilter(filter, btn) {
      document.querySelectorAll('.ms-filter, .ms2-tab').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var cards = document.querySelectorAll('.ms-card');
      cards.forEach(function(c){
        var val = c.getAttribute('data-ms-filter');
        c.style.display = (filter === 'all' || val === filter) ? '' : 'none';
      });
      msCheckEmpty();
    }
    function msGroupFilter(group, btn) {
      document.querySelectorAll('.ms-gpill, .ms2-gpill').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var cards = document.querySelectorAll('.ms-card');
      cards.forEach(function(c){
        var val = c.getAttribute('data-ms-group');
        c.style.display = (group === 'all' || val === group) ? '' : 'none';
      });
      msCheckEmpty();
    }
    function msCheckEmpty() {
      var visible = document.querySelectorAll('.ms-card:not([style*=\"display: none\"])');
      var empty = document.getElementById('msEmptyMsg');
      if (!empty) {
        empty = document.createElement('div');
        empty.id = 'msEmptyMsg';
        empty.className = 'ms-empty';
        empty.innerHTML = '<span class=\"ms-empty-icon\">⚽</span><p>لا توجد مباريات تطابق الفلتر</p>';
        document.getElementById('msMatchList').appendChild(empty);
      }
      if (visible.length === 0) { empty.style.display = ''; } else { empty.style.display = 'none'; }
    }

    // Mobile: Show More
    var msIdx = 8;
    (function msInit(){
      var cards = document.querySelectorAll('.ms-card');
      if (cards.length <= msIdx) return;
      for (var i = msIdx; i < cards.length; i++) cards[i].style.display = 'none';
      document.getElementById('msShowMore').style.display = '';
    })();
    function msLoadMore(){
      var cards = document.querySelectorAll('.ms-card');
      var end = Math.min(msIdx + 8, cards.length);
      for (var i = msIdx; i < end; i++) {
        var f = cards[i].getAttribute('data-ms-filter');
        var g = cards[i].getAttribute('data-ms-group');
        var actFilter = document.querySelector('.ms-filter.active');
        var actGroup = document.querySelector('.ms-gpill.active');
        var showF = !actFilter || actFilter.getAttribute('data-filter') === 'all' || actFilter.getAttribute('data-filter') === f;
        var showG = !actGroup || actGroup.getAttribute('data-group') === 'all' || actGroup.getAttribute('data-group') === g;
        cards[i].style.display = (showF && showG) ? '' : 'none';
      }
      msIdx = end;
      if (msIdx >= cards.length) document.getElementById('msShowMore').style.display = 'none';
    }
  </script>
<%- include('partials/mobile-nav', { active: 'schedule' }) %>
</body>
</html>
