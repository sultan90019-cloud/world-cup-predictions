<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>لوحة تحكم المدير</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
  <style>
    /* ===== DASHBOARD TABS ===== */
    .db-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:20px; }
    .db-tab { padding:9px 18px; border-radius:12px; border:1.5px solid var(--border); background:var(--surface); color:var(--text-secondary); font-weight:700; font-size:0.88rem; cursor:pointer; transition:all 0.2s; }
    .db-tab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
    .db-tab:hover:not(.active) { border-color:var(--primary); color:var(--primary); }
    .db-tab-badge { display:inline-block; background:#ef4444; color:#fff; border-radius:20px; padding:1px 7px; font-size:0.72rem; margin-right:4px; font-weight:800; }
    .db-panel { display:none; }
    .db-panel.active { display:block; }

    /* ===== PLAYERS CARDS ===== */
    .db-players-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }
    .db-player-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:16px; display:flex; flex-direction:column; gap:10px; }
    .db-player-top { display:flex; align-items:center; gap:12px; }
    .db-player-avatar { width:42px; height:42px; border-radius:50%; background:var(--primary-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .db-player-avatar svg { width:22px; height:22px; fill:var(--primary); }
    .db-player-info { flex:1; min-width:0; }
    .db-player-name { font-weight:700; font-size:0.95rem; color:var(--text); }
    .db-player-username { font-size:0.78rem; color:var(--text-secondary); }
    .db-status-badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; }
    .db-status-approved { background:rgba(34,197,94,0.12); color:#16a34a; }
    .db-status-pending { background:rgba(245,158,11,0.12); color:#d97706; }
    .db-status-rejected { background:rgba(239,68,68,0.12); color:#ef4444; }
    .db-player-actions { display:flex; gap:6px; flex-wrap:wrap; }
    .db-btn { padding:6px 14px; border-radius:8px; border:none; font-size:0.8rem; font-weight:700; cursor:pointer; transition:all 0.2s; }
    .db-btn-approve { background:#22c55e; color:#fff; }
    .db-btn-reject { background:#f59e0b; color:#fff; }
    .db-btn-delete { background:#ef4444; color:#fff; }
    .db-btn:hover { opacity:0.85; transform:translateY(-1px); }
    .db-pending-section { margin-bottom:20px; }
    .db-pending-title { font-size:0.85rem; font-weight:700; color:var(--text-secondary); margin-bottom:10px; text-transform:uppercase; letter-spacing:0.05em; }

    /* ===== PREDICTIONS CARDS (Accordion) ===== */
    .db-pred-match { background:var(--surface); border:1px solid var(--border); border-radius:12px; margin-bottom:8px; overflow:hidden; }
    .db-pred-match-header { padding:10px 14px; display:flex; align-items:center; justify-content:space-between; gap:8px; cursor:pointer; user-select:none; transition:background 0.15s; }
    .db-pred-match-header:hover { background:rgba(0,0,0,0.03); }
    .db-pred-match-title { font-weight:700; font-size:0.85rem; color:var(--text); display:flex; align-items:center; gap:6px; flex:1; min-width:0; }
    .db-pred-match-title img { width:18px; height:18px; border-radius:2px; object-fit:cover; flex-shrink:0; }
    .db-pred-match-right { display:flex; align-items:center; gap:6px; flex-shrink:0; }
    .db-pred-match-meta { font-size:0.75rem; color:var(--text-secondary); white-space:nowrap; }
    .db-pred-chevron { font-size:0.7rem; color:var(--text-secondary); transition:transform 0.2s; }
    .db-pred-match.open .db-pred-chevron { transform:rotate(180deg); }
    .db-pred-toggle { padding:4px 10px; border-radius:7px; border:none; font-size:0.75rem; font-weight:700; cursor:pointer; }
    .db-pred-toggle.show { background:#22c55e; color:#fff; }
    .db-pred-toggle.hide { background:#ef4444; color:#fff; }
    .db-pred-count { background:rgba(22,93,255,0.1); color:var(--primary); border-radius:20px; padding:2px 8px; font-size:0.72rem; font-weight:700; }
    .db-pred-body { display:none; padding:10px 14px; border-top:1px solid var(--border); background:rgba(0,0,0,0.01); }
    .db-pred-match.open .db-pred-body { display:block; }
    .db-pred-chips { display:flex; flex-wrap:wrap; gap:6px; }
    .db-pred-chip { display:flex; align-items:center; gap:6px; background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:4px 10px; font-size:0.78rem; }
    .db-pred-chip-name { font-weight:700; color:var(--text); }
    .db-pred-chip-score { background:var(--primary); color:#fff; border-radius:10px; padding:1px 7px; font-weight:800; font-size:0.75rem; }
    .db-pred-empty { color:var(--text-secondary); font-size:0.82rem; font-style:italic; }

    /* ===== KNOCKOUT BRACKET ===== */
    .ko-match-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:12px; margin-bottom:8px; }
    .ko-match-card.has-teams { border-color:var(--primary); }
    .ko-match-num { font-size:0.72rem; color:var(--text-secondary); font-weight:600; margin-bottom:8px; }
    .ko-teams-row { display:flex; align-items:center; gap:8px; margin-bottom:10px; flex-wrap:wrap; }
    .ko-team-select-wrap { flex:1; min-width:120px; display:flex; align-items:center; gap:6px; background:var(--surface-alt,#f8fafc); border:1px solid var(--border); border-radius:8px; padding:5px 8px; }
    .ko-flag-preview { width:22px; height:22px; border-radius:3px; object-fit:cover; flex-shrink:0; }
    .ko-team-select { flex:1; border:none; background:transparent; font-size:0.82rem; font-weight:600; color:var(--text); outline:none; cursor:pointer; }
    .ko-vs { font-size:0.78rem; color:var(--text-secondary); font-weight:700; flex-shrink:0; }
    .ko-save-btn { background:var(--primary); color:#fff; border:none; padding:6px 14px; border-radius:8px; font-size:0.8rem; font-weight:700; cursor:pointer; width:100%; margin-top:4px; }
    .ko-save-btn:hover { opacity:0.85; }
    .ko-section-title { font-size:0.82rem; font-weight:700; color:var(--text-secondary); margin:16px 0 8px; text-transform:uppercase; letter-spacing:0.06em; padding-right:4px; }
    .ko-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:10px; }

    /* ===== ROUNDS ===== */
    .db-rounds-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
    .db-round-card { background:var(--surface); border:1.5px solid var(--border); border-radius:14px; padding:16px; text-align:center; transition:all 0.2s; }
    .db-round-card.published { border-color:#22c55e; background:rgba(34,197,94,0.04); }
    .db-round-name { font-weight:800; font-size:1rem; color:var(--text); margin-bottom:4px; }
    .db-round-count { font-size:0.8rem; color:var(--text-secondary); margin-bottom:10px; }
    .db-round-badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; margin-bottom:10px; }
    .db-round-badge.pub { background:rgba(34,197,94,0.12); color:#16a34a; }
    .db-round-badge.unpub { background:rgba(148,163,184,0.12); color:#64748b; }
    .btn-publish { background:var(--primary); color:#fff; border:none; padding:7px 16px; border-radius:8px; font-size:0.82rem; font-weight:700; cursor:pointer; width:100%; }
    .btn-unpublish { background:#ef4444; color:#fff; border:none; padding:7px 16px; border-radius:8px; font-size:0.82rem; font-weight:700; cursor:pointer; width:100%; }

    /* ===== PRED GROUP TABS ===== */
    .pg-group-tabs { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:16px; }
    .pg-gtab { padding:6px 14px; border-radius:10px; border:1.5px solid var(--border); background:var(--surface); color:var(--text-secondary); font-weight:700; font-size:0.82rem; cursor:pointer; transition:all 0.18s; }
    .pg-gtab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
    .pg-gtab:hover:not(.active) { border-color:var(--primary); color:var(--primary); }
    .pg-group-panel { display:none; }
    .pg-group-panel.active { display:block; }
    .pg-round-filter { display:flex; gap:6px; margin-bottom:12px; flex-wrap:wrap; }
    .pg-rfbtn { padding:4px 12px; border-radius:8px; border:1.5px solid var(--border); background:transparent; color:var(--text-secondary); font-size:0.78rem; font-weight:700; cursor:pointer; transition:all 0.15s; }
    .pg-rfbtn.active { background:var(--primary); color:#fff; border-color:var(--primary); }

    /* ===== PRED MATCH ROW ===== */
    .pg-match-row { display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:10px; border:1px solid var(--border); margin-bottom:6px; cursor:pointer; transition:background 0.15s,border-color 0.15s; }
    .pg-match-row:hover { background:rgba(22,93,255,0.04); border-color:var(--primary); }
    .pg-match-teams { flex:1; display:flex; align-items:center; gap:6px; font-weight:700; font-size:0.85rem; min-width:0; }
    .pg-flag { width:20px; height:20px; border-radius:3px; object-fit:cover; flex-shrink:0; }
    .pg-vs { font-size:0.72rem; color:var(--text-secondary); margin:0 3px; flex-shrink:0; }
    .pg-team-name { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:100px; }
    .pg-match-meta { display:flex; align-items:center; gap:6px; flex-shrink:0; }
    .pg-count { background:rgba(22,93,255,0.10); color:var(--primary); border-radius:20px; padding:2px 8px; font-size:0.72rem; font-weight:800; }
    .pg-vis-icon { font-size:0.9rem; }
    .pg-toggle-form { margin:0; }
    .pg-toggle-btn { padding:3px 8px; border-radius:7px; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; }
    .pg-toggle-btn.show { background:#22c55e; }
    .pg-toggle-btn.hide { background:#ef4444; }
    .pg-toggle-btn svg { width:14px; height:14px; fill:#fff; display:block; }
    .pg-ko-section { margin-top:20px; border-top:2px solid var(--border); padding-top:16px; }
    .pg-ko-title { font-size:0.82rem; font-weight:800; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:10px; }

    /* ===== ROUND PANELS (NEW) ===== */
    .pg-round-panel-main { display:none; }
    .pg-round-panel-main.active { display:block; }
    .pg-bulk-header { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:14px; padding:10px 12px; background:var(--surface-alt,#f8fafc); border-radius:10px; border:1px solid var(--border); }
    .pg-bulk-info { display:flex; align-items:center; gap:8px; }
    .pg-badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; background:rgba(148,163,184,0.12); color:#64748b; }
    .pg-badge.published { background:rgba(34,197,94,0.12); color:#16a34a; }
    .pg-badge.partial { background:rgba(245,158,11,0.12); color:#d97706; }
    .pg-bulk-form { margin:0; }
    .pg-bulk-btn { padding:6px 14px; border-radius:8px; border:none; font-size:0.78rem; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:6px; transition:opacity 0.2s; }
    .pg-bulk-btn:hover { opacity:0.85; }
    .pg-bulk-btn.show { background:#22c55e; color:#fff; }
    .pg-bulk-btn.hide { background:#ef4444; color:#fff; }
    .pg-matches-list { max-height:60vh; overflow-y:auto; }
    .pg-match-row.visible { border-left:3px solid #22c55e; }
    .pg-group-badge { background:rgba(99,102,241,0.10); color:#6366f1; border-radius:20px; padding:2px 8px; font-size:0.7rem; font-weight:700; }

    /* ===== RESULTS ===== */
    .db-result-card { border-left:3px solid transparent; transition:border-color 0.2s; }
    .db-result-card.has-result { border-left:3px solid #22c55e; background:rgba(34,197,94,0.03); }

    /* ===== PREDICTIONS MODAL ===== */
    .pred-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9000; display:none; align-items:center; justify-content:center; padding:16px; }
    .pred-modal-overlay.open { display:flex; }
    .pred-modal { background:var(--surface); border-radius:16px; width:100%; max-width:520px; max-height:80vh; display:flex; flex-direction:column; box-shadow:0 20px 60px rgba(0,0,0,0.3); overflow:hidden; }
    .pred-modal-header { padding:16px 18px 12px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:8px; }
    .pred-modal-title { flex:1; font-weight:800; font-size:0.92rem; color:var(--text); display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
    .pred-modal-close { background:none; border:none; font-size:1.1rem; cursor:pointer; color:var(--text-secondary); padding:4px 8px; border-radius:6px; flex-shrink:0; }
    .pred-modal-close:hover { background:rgba(0,0,0,0.06); }
    .pred-modal-body { flex:1; overflow-y:auto; padding:14px 18px; }
    .pred-modal-footer { padding:12px 18px; border-top:1px solid var(--border); }
    .pm-flag { width:22px; height:22px; border-radius:3px; object-fit:cover; }
    .pm-vs { color:var(--text-secondary); font-size:0.75rem; margin:0 4px; }
    .pm-chips { display:flex; flex-wrap:wrap; gap:8px; }
    .pm-chip { display:flex; align-items:center; gap:6px; background:var(--surface-alt,#f8fafc); border:1px solid var(--border); border-radius:20px; padding:5px 12px; }
    .pm-name { font-weight:700; font-size:0.82rem; color:var(--text); }
    .pm-score { background:var(--primary); color:#fff; border-radius:10px; padding:2px 8px; font-weight:800; font-size:0.78rem; }
    .pm-empty { color:var(--text-secondary); font-size:0.85rem; font-style:italic; text-align:center; padding:20px 0; }
    .pm-chip-miss { border-color:rgba(239,68,68,0.25); background:rgba(239,68,68,0.06); }
    .pm-del-btn { background:none; border:none; cursor:pointer; font-size:0.8rem; padding:0 2px; opacity:0.5; transition:opacity 0.15s; }
    .pm-del-btn:hover { opacity:1; }
    .pm-save-btn { background:#22c55e; border:none; cursor:pointer; font-size:0.75rem; padding:4px 8px; border-radius:8px; color:#fff; font-weight:700; transition:opacity 0.15s; }
    .pm-save-btn:hover { opacity:0.8; }
    .pm-score-miss { background:transparent; color:#ef4444; font-size:0.75rem; padding:2px 4px; font-weight:700; }
    .pm-countdown { font-size:1.1rem; color:#ef4444; margin-bottom:12px; padding:10px 14px; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); border-radius:10px; text-align:center; font-weight:800; }
    .pm-btn { width:100%; padding:9px; border-radius:8px; border:none; font-size:0.85rem; font-weight:700; cursor:pointer; }
    .pm-btn-show { background:#22c55e; color:#fff; }
    .pm-btn-hide { background:#ef4444; color:#fff; }
    .pm-btn:hover { opacity:0.85; }

    /* ===== NEWS ADMIN ===== */
    .news-add-form { display:flex; flex-direction:column; gap:10px; }
    .news-form-row { display:flex; gap:8px; }
    .news-input { flex:1; padding:9px 12px; border-radius:10px; border:1.5px solid var(--border); background:var(--surface); color:var(--text); font-size:0.88rem; font-family:inherit; outline:none; transition:border-color 0.15s; }
    .news-input:focus { border-color:var(--primary); }
    .news-textarea { resize:vertical; min-height:70px; }
    .news-form-bottom { align-items:center; flex-wrap:wrap; gap:10px; }
    .news-file-label { display:flex; align-items:center; gap:6px; padding:7px 12px; border-radius:10px; border:1.5px dashed var(--border); cursor:pointer; font-size:0.82rem; color:var(--text-secondary); transition:border-color 0.15s; }
    .news-file-label:hover { border-color:var(--primary); color:var(--primary); }
    .news-breaking-label { display:flex; align-items:center; gap:5px; font-size:0.84rem; font-weight:700; cursor:pointer; color:var(--text); }
    .news-list-admin { display:flex; flex-direction:column; gap:10px; }
    .news-admin-row { display:flex; align-items:flex-start; gap:12px; padding:12px; border:1px solid var(--border); border-radius:12px; background:var(--surface); }
    .news-admin-img { width:80px; height:56px; object-fit:cover; border-radius:8px; flex-shrink:0; }
    .news-admin-body { flex:1; min-width:0; }
    .news-admin-title { font-weight:700; font-size:0.88rem; color:var(--text); margin-bottom:4px; display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
    .news-admin-excerpt { font-size:0.8rem; color:var(--text-secondary); margin:4px 0; line-height:1.5; }

    /* ===== RESULTS ===== */
    .db-result-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:12px 16px; margin-bottom:8px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .db-result-teams { flex:1; min-width:160px; display:flex; align-items:center; gap:6px; font-weight:700; font-size:0.88rem; }
    .db-result-flag { width:22px; height:22px; object-fit:cover; border-radius:3px; }
    .db-result-vs { color:var(--text-secondary); font-size:0.78rem; margin:0 4px; }
    .db-result-actual { font-weight:800; color:#16a34a; font-size:0.9rem; min-width:40px; text-align:center; }
    .db-result-form { display:flex; align-items:center; gap:6px; }

    @media (max-width:600px) {
      .db-tabs { gap:4px; }
      .db-tab { padding:7px 12px; font-size:0.8rem; }
      .db-players-grid { grid-template-columns:1fr; }
      .db-rounds-grid { grid-template-columns:1fr 1fr; }
    }
    /* ===== MISSED PREDICTIONS BADGES ===== */
    .mp-badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.78rem; font-weight:800; cursor:pointer; transition:all 0.15s; }
    .mp-badge.mp-green { background:rgba(34,197,94,0.15); color:#16a34a; }
    .mp-badge.mp-yellow { background:rgba(245,158,11,0.15); color:#d97706; }
    .mp-badge.mp-red { background:rgba(239,68,68,0.15); color:#ef4444; }
    .mp-badge:hover { opacity:0.8; transform:scale(1.05); }
  </style>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'dashboard', user: user }) %>
    <main class="main-content">
      <%- include('partials/topbar', { pageTitle: 'لوحة التحكم', user: user }) %>
      <section class="page-content">


        <%
          var roundNames = {
            1: 'الجولة الأولى (دور المجموعات)',
            2: 'الجولة الثانية (دور المجموعات)',
            3: 'الجولة الثالثة (دور المجموعات)',
            4: 'دور الـ 32',
            5: 'دور الـ 16',
            6: 'دور الـ 8',
            7: 'دور الـ 4',
            8: 'النهائي'
          };
        %>

        <!-- ===== TABS NAV ===== -->
        <div class="db-tabs">
          <button class="db-tab <%= activeTab==='players'?'active':'' %>" onclick="dbTab('players',this)">
            <% if (pendingUsers.length > 0) { %><span class="db-tab-badge"><%= pendingUsers.length %></span><% } %>
            المتسابقون
          </button>
          <button class="db-tab <%= activeTab==='predictions'?'active':'' %>" onclick="dbTab('predictions',this)">التوقعات</button>
          <button class="db-tab <%= activeTab==='results'?'active':'' %>" onclick="dbTab('results',this)">النتائج</button>
          <button class="db-tab <%= activeTab==='rounds'?'active':'' %>" onclick="dbTab('rounds',this)">الجولات</button>
          <button class="db-tab <%= activeTab==='seeding'?'active':'' %>" onclick="dbTab('seeding',this)">تسكين دور الـ32</button>
          <button class="db-tab <%= activeTab==='leaderboard'?'active':'' %>" onclick="dbTab('leaderboard',this)">الترتيب</button>
          <button class="db-tab <%= activeTab==='news'?'active':'' %>" onclick="dbTab('news',this)">الأخبار</button>
          <button class="db-tab <%= activeTab==='comments'?'active':'' %>" onclick="dbTab('comments',this)">التعليقات</button>
          <button class="db-tab <%= activeTab==='challenge'?'active':'' %>" onclick="dbTab('challenge',this)">لعبة التحدي</button>
          <button class="db-tab <%= activeTab==='settings'?'active':'' %>" onclick="dbTab('settings',this)">الإعدادات</button>
        </div>

        <!-- ===== TAB: المتسابقون ===== -->
        <div class="db-panel <%= activeTab==='players'?'active':'' %>" id="panel-players">

          <% if (pendingUsers.length > 0) { %>
          <div class="card section-card db-pending-section">
            <div class="db-pending-title">بانتظار الموافقة (<%= pendingUsers.length %>)</div>
            <div class="db-players-grid">
              <% pendingUsers.forEach(function(u) { %>
              <div class="db-player-card">
                <div class="db-player-top">
                  <div class="db-player-avatar">
                    <svg viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
                  </div>
                  <div class="db-player-info">
                    <div class="db-player-name"><%= u.name %></div>
                    <div class="db-player-username">@<%= u.username %></div>
                  </div>
                  <span class="db-status-badge db-status-pending">بانتظار</span>
                </div>
                <div class="db-player-actions">
                  <form method="POST" action="/admin/approve/<%= u.id %>" style="margin:0;">
                    <button type="submit" class="db-btn db-btn-approve">✓ قبول</button>
                  </form>
                  <form method="POST" action="/admin/reject/<%= u.id %>" style="margin:0;">
                    <button type="submit" class="db-btn db-btn-reject">✕ رفض</button>
                </form>
              </div>

              <!-- فحص المسار -->
              <% if (bracketVerification) { %>
              <div style="margin-top:20px;padding:14px;background:var(--bg);border-radius:10px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                  <span style="font-weight:700;font-size:0.9rem;">فحص مسار الأدوار الإقصائية</span>
                  <% if (bracketVerification.valid) { %>
                    <span style="background:#16a34a;color:#fff;padding:2px 10px;border-radius:12px;font-size:0.7rem;font-weight:700;">✓ سليم</span>
                  <% } else { %>
                    <span style="background:#dc2626;color:#fff;padding:2px 10px;border-radius:12px;font-size:0.7rem;font-weight:700;">✗ مشاكل</span>
                  <% } %>
                </div>
                <!-- إحصائيات -->
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                  <% var roundLabels = {4:'R32',5:'R16',6:'QF',7:'SF',8:'FINAL'}; %>
                  <% for (var r = 4; r <= 8; r++) { %>
                    <% var c = bracketVerification.counts[r]; %>
                    <span style="font-size:0.75rem;background:var(--surface);padding:4px 10px;border-radius:6px;border:1px solid var(--border);">
                      <strong><%= roundLabels[r] %></strong>: <%= c.total %> مباريات
                      (<%= c.with_label %> مسار)
                    </span>
                  <% } %>
                </div>
                <% if (bracketVerification.issues.length > 0) { %>
                  <div style="font-size:0.8rem;color:#dc2626;">
                    <% bracketVerification.issues.forEach(function(issue) { %>
                      <div style="padding:2px 0;">• <%= issue %></div>
                    <% }); %>
                  </div>
                <% } %>
                <% if (bracketVerification.warnings.length > 0) { %>
                  <div style="font-size:0.78rem;color:#d97706;margin-top:6px;">
                    <% bracketVerification.warnings.forEach(function(w) { %>
                      <div style="padding:2px 0;">• <%= w %></div>
                    <% }); %>
                  </div>
                <% } %>
              </div>
              <% } %>

              <div style="margin-top:16px;">
                <form method="POST" action="/admin/rebuild-knockout" style="margin:0;" onsubmit="return confirm('تحذير! إعادة بناء الأدوار الإقصائية:\n\n• سيتم إعادة تعيين جميع المواجهات إلى الوضع الافتراضي\n• لن يتم حذف النتائج أو التوقعات\n• سيتم إنشاء backup تلقائي قبل التنفيذ\n• لا يمكن التراجع عن هذا الإجراء\n\nهل أنت متأكد؟')">
                  <button type="submit" class="db-btn" style="padding:10px 20px;font-size:0.85rem;background:#dc2626;color:#fff;border:none;border-radius:10px;cursor:pointer;">
                    إعادة بناء الأدوار الإقصائية
                  </button>
                </form>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <div class="card section-card">
            <div class="db-pending-title">جميع المتسابقين (<%= allUsers.filter(function(u){return u.role!=='admin'}).length %>)</div>
            <div class="db-players-grid">
              <% allUsers.forEach(function(u) { %>
              <div class="db-player-card">
                <div class="db-player-top">
                  <div class="db-player-avatar">
                    <svg viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
                  </div>
                  <div class="db-player-info">
                    <div class="db-player-name"><%= u.name %></div>
                    <div class="db-player-username">@<%= u.username %> · <%= u.role === 'admin' ? 'مدير' : 'متسابق' %></div>
                  </div>
                  <% if (u.status === 'approved') { %>
                    <span class="db-status-badge db-status-approved">مقبول</span>
                  <% } else if (u.status === 'pending') { %>
                    <span class="db-status-badge db-status-pending">بانتظار</span>
                  <% } else { %>
                    <span class="db-status-badge db-status-rejected">مرفوض</span>
                  <% } %>
                </div>
                <% if (u.role !== 'admin') { %>
                <div class="db-player-actions">
                  <% if (u.status === 'pending') { %>
                  <form method="POST" action="/admin/approve/<%= u.id %>" style="margin:0;">
                    <button type="submit" class="db-btn db-btn-approve">✓ قبول</button>
                  </form>
                  <% } %>
                  <form method="POST" action="/admin/manual-points" style="margin:0;display:flex;align-items:center;gap:4px;">
                    <input type="hidden" name="userId" value="<%= u.id %>">
                    <input type="number" name="points" value="<%= u.manual_points || 0 %>" min="0" style="width:50px;padding:4px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);text-align:center;font-size:0.85rem;" title="نقاط تعويضية">
                    <button type="submit" class="db-btn db-btn-approve" style="font-size:0.75rem;padding:4px 8px;" title="حفظ النقاط التعويضية">💾</button>
                  </form>
                  <form method="POST" action="/admin/delete/<%= u.id %>" style="margin:0;" onsubmit="return confirm('حذف <%= u.name %>؟ سيتم حذف جميع توقعاته.');">
                    <button type="submit" class="db-btn db-btn-delete">🗑 حذف</button>
                  </form>
                </div>
                <% } %>
              </div>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- ===== TAB: التوقعات ===== -->
        <div class="db-panel <%= activeTab==='predictions'?'active':'' %>" id="panel-predictions">
          <div class="card section-card">
            <p style="color:var(--text-secondary);font-size:0.82rem;margin-bottom:14px;">اختر جولة · اضغط على المباراة لعرض توقعات المتسابقين · استخدم زر "نشر جماعي" لنشر/إخفاء جميع توقعات الجولة</p>

            <%
              var allRoundDefs = [
                { round:1, name:'الجولة الأولى', type:'group' },
                { round:2, name:'الجولة الثانية', type:'group' },
                { round:3, name:'الجولة الثالثة', type:'group' },
                { round:4, name:'دور الـ 32', type:'ko' },
                { round:5, name:'دور الـ 16', type:'ko' },
                { round:6, name:'دور الـ 8', type:'ko' },
                { round:7, name:'دور الـ 4', type:'ko' },
                { round:8, name:'النهائي', type:'ko' }
              ];
              var roundDefs = allRoundDefs.filter(function(rd) {
                return (matchesByRound[rd.round] || []).length > 0;
              });
              var firstRoundIdx = roundDefs.length > 0 ? 0 : -1;
            %>

            <!-- Round Tabs -->
            <div class="pg-group-tabs">
              <% roundDefs.forEach(function(rd, ri) { %>
              <button class="pg-gtab <%= ri===firstRoundIdx?'active':'' %>"
                      onclick="pgSwitchRoundTab(<%= ri %>,this)">
                <%= rd.name %>
              </button>
              <% }) %>
            </div>

            <!-- Round Panels -->
            <% roundDefs.forEach(function(rd, ri) {
               var roundMatches = matchesByRound[rd.round] || [];
                var roundVisibleCount = roundMatches.filter(function(m) {
                  var start = new Date(m.start_at);
                  var lockTime = new Date(start.getTime() - 10 * 60 * 1000);
                  var deadlinePassed = Date.now() >= lockTime.getTime();
                  var isManuallyHidden = hiddenPredictions.includes(m.id);
                  var isManuallyVisible = visiblePredictions.includes(m.id);
                  return (deadlinePassed && !isManuallyHidden) || isManuallyVisible;
                }).length;
               var isRoundFullyVisible = roundMatches.length > 0 && roundVisibleCount === roundMatches.length;
               var isRoundPartiallyVisible = roundVisibleCount > 0 && roundVisibleCount < roundMatches.length;
            %>
            <div class="pg-round-panel-main <%= ri===firstRoundIdx?'active':'' %>" id="pg-round-panel-<%= ri %>">

              <!-- Bulk Action Header -->
              <div class="pg-bulk-header">
                <div class="pg-bulk-info">
                  <span class="pg-badge <%= isRoundFullyVisible?'published':(isRoundPartiallyVisible?'partial':'') %>">
                    <%= roundVisibleCount %> / <%= roundMatches.length %> مباريات منشورة
                  </span>
                </div>
                <form method="POST" action="/admin/toggle-round-predictions" class="pg-bulk-form">
                  <input type="hidden" name="round" value="<%= rd.round %>">
                  <input type="hidden" name="action" value="<%= isRoundFullyVisible?'hide':'show' %>">
                  <button type="submit" class="pg-bulk-btn <%= isRoundFullyVisible?'hide':'show' %>">
                    <% if (isRoundFullyVisible) { %>
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                      إخفاء جماعي
                    <% } else { %>
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 1C9.24 1 7 3.24 7 6v1H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2h-1V6c0-2.76-2.24-5-5-5zm0 2c1.66 0 3 1.34 3 3v1H9V6c0-1.66 1.34-3 3-3zm0 9c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z"/></svg>
                      نشر جماعي
                    <% } %>
                  </button>
                </form>
              </div>

              <!-- Matches List -->
              <div class="pg-matches-list">
                <% if (roundMatches.length === 0) { %>
                  <p style="color:var(--text-secondary);font-size:0.83rem;padding:8px 0;">لا توجد مباريات في هذه الجولة</p>
                <% } else { %>
                  <% roundMatches.forEach(function(match) {
                       var preds = (matchPredictions && matchPredictions[match.id]) ? matchPredictions[match.id] : [];
                       var start = new Date(match.start_at);
                       var lockTime = new Date(start.getTime() - 10 * 60 * 1000);
                       var deadlinePassed = Date.now() >= lockTime.getTime();
                       var isManuallyHidden = hiddenPredictions.includes(match.id);
                       var isManuallyVisible = visiblePredictions.includes(match.id);
                       var isVisible = (deadlinePassed && !isManuallyHidden) || isManuallyVisible;
                  %>
                  <div class="pg-match-row <%= isVisible?'visible':'' %>" onclick="openPredModal(<%= match.id %>)">
                    <div class="pg-match-teams">
                      <img src="/flags/<%= teamFlags[match.teamA]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" class="pg-flag">
                      <span class="pg-team-name"><%= match.teamA %></span>
                      <span class="pg-vs">VS</span>
                      <img src="/flags/<%= teamFlags[match.teamB]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" class="pg-flag">
                      <span class="pg-team-name"><%= match.teamB %></span>
                    </div>
                    <div class="pg-match-meta" onclick="event.stopPropagation()">
                      <% if (preds.length > 0) { %><span class="pg-count"><%= preds.length %></span><% } %>
                      <% if (match.group) { %><span class="pg-group-badge"><%= match.group %></span><% } %>
                      <form class="pg-toggle-form" method="POST" action="/admin/toggle-predictions/<%= match.id %>">
                        <button type="submit" class="pg-toggle-btn <%= isVisible?'hide':'show' %>">
                          <% if (isVisible) { %>
                          <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                          <% } else { %>
                          <svg viewBox="0 0 24 24"><path d="M12 1C9.24 1 7 3.24 7 6v1H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2h-1V6c0-2.76-2.24-5-5-5zm0 2c1.66 0 3 1.34 3 3v1H9V6c0-1.66 1.34-3 3-3zm0 9c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z"/></svg>
                          <% } %>
                        </button>
                      </form>
                    </div>
                  </div>
                  <% }) %>
                <% } %>
              </div>

            </div>
            <% }) %>

          </div>
        </div>

        <!-- ===== PREDICTIONS MODAL ===== -->
        <div class="pred-modal-overlay" id="predModalOverlay" onclick="closePredModal()">
          <div class="pred-modal" onclick="event.stopPropagation()">
            <div class="pred-modal-header">
              <div class="pred-modal-title" id="predModalTitle"></div>
              <button class="pred-modal-close" onclick="closePredModal()">✕</button>
            </div>
            <div class="pred-modal-body" id="predModalBody"></div>
            <div class="pred-modal-footer" id="predModalFooter"></div>
          </div>
        </div>

        <script id="pred-data" type="application/json"><%- JSON.stringify({
          approvedUsers: (allUsers||[]).filter(function(u){ return u.role !== 'admin' && u.status === 'approved'; }).map(function(u){ return {id: u.id, name: u.name}; }),
          matches: matches.map(function(m){
            var s = new Date(m.start_at);
            var lt = new Date(s.getTime() - 10 * 60 * 1000);
            var dp = Date.now() >= lt.getTime();
            var mh = hiddenPredictions.includes(m.id);
            var mv = visiblePredictions.includes(m.id);
            return {
              id: m.id,
              teamA: m.teamA,
              teamB: m.teamB,
              flagA: teamFlags[m.teamA]||'unknown',
              flagB: teamFlags[m.teamB]||'unknown',
              date: new Date(m.start_at).toLocaleDateString('ar-EG',{weekday:'short',month:'short',day:'numeric',timeZone:'Asia/Riyadh'}),
              visible: (dp && !mh) || mv,
              lockTime: lt.getTime(),
              preds: (matchPredictions && matchPredictions[m.id]) ? matchPredictions[m.id].map(function(p){ return {userId: p.user_id, name: p.user_name||p.username, a:p.scoreA, b:p.scoreB}; }) : []
            };
          })
        }) %></script>

        <!-- ===== TAB: النتائج ===== -->
        <div class="db-panel <%= activeTab==='results'?'active':'' %>" id="panel-results">
          <div class="card section-card">
            <p style="color:var(--text-secondary);font-size:0.82rem;margin-bottom:14px;">اختر جولة · أدخل النتيجة واضغط حفظ</p>

            <%
              var resRoundDefs = [
                { round:1, name:'الجولة الأولى', type:'group' },
                { round:2, name:'الجولة الثانية', type:'group' },
                { round:3, name:'الجولة الثالثة', type:'group' },
                { round:4, name:'دور الـ 32', type:'ko' },
                { round:5, name:'دور الـ 16', type:'ko' },
                { round:6, name:'دور الـ 8', type:'ko' },
                { round:7, name:'دور الـ 4', type:'ko' },
                { round:8, name:'النهائي', type:'ko' }
              ];
              var resultsRoundDefs = resRoundDefs.filter(function(rd) {
                return (matchesByRound[rd.round] || []).length > 0;
              });
              var firstResRoundIdx = resultsRoundDefs.length > 0 ? 0 : -1;
            %>

            <%
              var resTodayKey = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
              var resYesterdayD = new Date(); resYesterdayD.setDate(resYesterdayD.getDate() - 1);
              var resYesterdayKey = resYesterdayD.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
              var resTomorrowD = new Date(); resTomorrowD.setDate(resTomorrowD.getDate() + 1);
              var resTomorrowKey = resTomorrowD.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
              function getResDateKey(d) {
                if (!d) return '';
                try { return new Date(d).toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' }); }
                catch(e) { return ''; }
              }
              var resAllMatches = [];
              resultsRoundDefs.forEach(function(rd) {
                (matchesByRound[rd.round] || []).forEach(function(m) { resAllMatches.push(m); });
              });
              var resCountAll = resAllMatches.length, resCountToday = 0, resCountYesterday = 0, resCountTomorrow = 0;
              resAllMatches.forEach(function(m) {
                var dk = getResDateKey(m.start_at);
                if (dk === resTodayKey) resCountToday++;
                else if (dk === resYesterdayKey) resCountYesterday++;
                else if (dk === resTomorrowKey) resCountTomorrow++;
              });
            %>
            <!-- Date Filters -->
            <div class="pg-group-tabs" id="res-date-filters" style="margin-bottom:8px;">
              <button class="pg-gtab active" data-res-date="all" onclick="resDateFilter('all',this)">الكل (<%= resCountAll %>)</button>
              <button class="pg-gtab" data-res-date="yesterday" onclick="resDateFilter('yesterday',this)">أمس (<%= resCountYesterday %>)</button>
              <button class="pg-gtab" data-res-date="today" onclick="resDateFilter('today',this)">اليوم (<%= resCountToday %>)</button>
              <button class="pg-gtab" data-res-date="tomorrow" onclick="resDateFilter('tomorrow',this)">غداً (<%= resCountTomorrow %>)</button>
            </div>

            <!-- Round Tabs -->
            <div class="pg-group-tabs" id="res-round-tabs">
              <% resultsRoundDefs.forEach(function(rd, ri) { %>
              <button class="pg-gtab <%= ri===firstResRoundIdx?'active':'' %>"
                      onclick="resSwitchRoundTab(<%= ri %>,this)">
                <%= rd.name %>
              </button>
              <% }) %>
            </div>

            <!-- Round Panels -->
            <% resultsRoundDefs.forEach(function(rd, ri) {
               var roundMatches = matchesByRound[rd.round] || [];
            %>
            <div class="pg-round-panel-main <%= ri===firstResRoundIdx?'active':'' %>" id="res-round-panel-<%= ri %>">

              <div class="pg-bulk-header">
                <div class="pg-bulk-info">
                  <span class="pg-badge <%= rd.type==='group'?'':'published' %>">
                    <%= roundMatches.length %> مباراة
                  </span>
                  <% if (rd.type === 'group') { %>
                    <span class="pg-badge">دور المجموعات</span>
                  <% } else { %>
                    <span class="pg-badge published">أدوار إقصائية</span>
                  <% } %>
                </div>
              </div>

              <!-- Matches List -->
              <div class="pg-matches-list">
                <% if (roundMatches.length === 0) { %>
                  <p style="color:var(--text-secondary);font-size:0.83rem;padding:8px 0;">لا توجد مباريات في هذه الجولة</p>
                <% } else { %>
                  <% roundMatches.forEach(function(match) { %>
                  <div class="db-result-card <%= match.actual_scoreA !== null?'has-result':'' %>" data-rs-date="<%= getResDateKey(match.start_at) %>">
                    <div class="db-result-teams">
                      <img src="/flags/<%= teamFlags[match.teamA]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" class="db-result-flag">
                      <span class="pg-team-name" style="max-width:none"><%= match.teamA %></span>
                      <span class="db-result-vs">VS</span>
                      <span class="pg-team-name" style="max-width:none"><%= match.teamB %></span>
                      <img src="/flags/<%= teamFlags[match.teamB]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" class="db-result-flag">
                    </div>
                    <% if (match.actual_scoreA !== null) { %>
                      <span class="db-result-actual"><%= match.actual_scoreA %> - <%= match.actual_scoreB %></span>
                    <% } %>
                    <form method="POST" action="/matches/<%= match.id %>/result" class="db-result-form" id="res-form-<%= match.id %>">
                      <input type="number" name="scoreA" min="0" max="99" value="<%= match.actual_scoreA !== null ? match.actual_scoreA : '' %>" placeholder="0" class="score-input" style="width:48px;" oninput="dbTogglePenalty(this)">
                      <span>-</span>
                      <input type="number" name="scoreB" min="0" max="99" value="<%= match.actual_scoreB !== null ? match.actual_scoreB : '' %>" placeholder="0" class="score-input" style="width:48px;" oninput="dbTogglePenalty(this)">
                      <% if (match.round >= 4) { %>
                      <select name="actualWinner" style="padding:4px 6px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:0.78rem;font-weight:600;">
                        <option value="">المتأهل</option>
                        <option value="<%= match.teamA %>" <%= match.actual_winner === match.teamA ? 'selected' : '' %>><%= match.teamA %></option>
                        <option value="<%= match.teamB %>" <%= match.actual_winner === match.teamB ? 'selected' : '' %>><%= match.teamB %></option>
                      </select>
                      <!-- Penalty winner (يظهر فقط عند التعادل في الإقصائيات) -->
                      <select name="penaltyWinner" id="dbPenalty<%= match.id %>" style="display:none;padding:4px 6px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:0.78rem;font-weight:600;">
                        <option value="">الفائز بركلات الترجيح</option>
                        <option value="<%= match.teamA %>" <%= match.penalty_winner === match.teamA ? 'selected' : '' %>><%= match.teamA %></option>
                        <option value="<%= match.teamB %>" <%= match.penalty_winner === match.teamB ? 'selected' : '' %>><%= match.teamB %></option>
                      </select>
                      <% } %>
                      <button type="submit" class="btn-save">حفظ</button>
                      <% if (match.actual_scoreA !== null) { %>
                      <button type="button" class="btn-clear" onclick="clearResult('<%= match.id %>')" title="مسح النتيجة">مسح</button>
                      <% } %>
                    </form>
                  </div>
                  <% }) %>
                <% } %>
              </div>

            </div>
            <% }) %>

          </div>
        </div>


        <!-- ===== TAB: الجولات ===== -->
        <div class="db-panel <%= activeTab==='rounds'?'active':'' %>" id="panel-rounds">
          <div class="card section-card">
            <p style="color:var(--text-secondary);font-size:0.85rem;margin-bottom:16px;">
              المتسابقون يرون فقط مباريات الجولات/الأدوار المنشورة.
            </p>
            <div class="db-rounds-grid">
              <% [1,2,3,4,5,6,7,8].forEach(function(r) { %>
              <div class="db-round-card <%= publishedRounds.includes(r) ? 'published' : '' %>">
                <div class="db-round-name"><%= roundNames[r] %></div>
                <div class="db-round-count"><%= matchesByRound[r] ? matchesByRound[r].length : 0 %> مباراة</div>
                <span class="db-round-badge <%= publishedRounds.includes(r) ? 'pub' : 'unpub' %>">
                  <%= publishedRounds.includes(r) ? '✓ منشورة' : 'غير منشورة' %>
                </span>
                <% if (publishedRounds.includes(r)) { %>
                  <form method="POST" action="/admin/unpublish-round" style="margin-top:8px;">
                    <input type="hidden" name="round" value="<%= r %>">
                    <button type="submit" class="btn-unpublish">إلغاء النشر</button>
                  </form>
                <% } else { %>
                  <form method="POST" action="/admin/publish-round" style="margin-top:8px;">
                    <input type="hidden" name="round" value="<%= r %>">
                    <button type="submit" class="btn-publish">نشر الآن</button>
                  </form>
                <% } %>
              </div>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- ===== TAB: تسكين دور الـ32 ===== -->
        <div class="db-panel <%= activeTab==='seeding'?'active':'' %>" id="panel-seeding">

          <% if (!bracketStatus || !bracketStatus.confirmed) { %>

            <!-- ---- مرحلة التسكين ---- -->
            <div class="card section-card">
              <div style="font-weight:800;font-size:1rem;margin-bottom:16px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <span>جدول دور الـ 32 — تسكين أفضل 8 ثوالث</span>
                <% if (bestThirds && bestThirds.length > 0) { %>
                  <span style="font-size:0.75rem;color:var(--text-secondary);background:var(--bg);padding:4px 10px;border-radius:20px;">
                    أفضل 8 ثوالث متاحة
                  </span>
                <% } %>
              </div>

              <% if (seedingPairings && seedingPairings.length > 0) { %>
                <form method="POST" action="/admin/seeding-save" id="seeding-form">
                  <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;font-size:0.85rem;">
                      <thead>
                        <tr style="background:var(--bg);">
                          <th style="padding:10px 12px;text-align:right;">#</th>
                          <th style="padding:10px 12px;text-align:right;">المباراة</th>
                          <th style="padding:10px 12px;text-align:right;">الفريق A</th>
                          <th style="padding:10px 12px;text-align:right;">الفريق B</th>
                          <th style="padding:10px 12px;text-align:right;">يتأهل إلى</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% seedingPairings.forEach(function(p, i) { %>
                        <tr style="border-bottom:1px solid var(--border);">
                          <td style="padding:10px 12px;"><%= i + 1 %></td>
                          <td style="padding:10px 12px;font-weight:700;font-size:0.8rem;color:var(--primary);"><%= p.label %></td>
                          <td style="padding:10px 12px;">
                            <% if (p.teamA) { %>
                              <span style="display:inline-flex;align-items:center;gap:6px;">
                                <img src="/flags/<%= teamFlags[p.teamA]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" style="width:18px;height:12px;border-radius:2px;">
                                <%= p.teamA %>
                                <% if (p.teamA_auto) { %><span style="font-size:0.65rem;color:#16a34a;">(تلقائي)</span><% } %>
                              </span>
                            <% } else { %>
                              <span style="color:var(--text-secondary);">—</span>
                            <% } %>
                          </td>
                          <td style="padding:10px 12px;">
                            <% if (p.is_third_slot) { %>
                              <!-- Dropdown لأفضل الثوالث -->
                              <select name="third_<%= p.label.replace('R32-','') %>" style="padding:8px 10px;border:1.5px solid var(--border);border-radius:8px;font-size:0.8rem;background:var(--surface);min-width:130px;">
                                <option value="">اختر الثالث</option>
                                <% if (p.available_thirds) { p.available_thirds.forEach(function(t) { %>
                                  <option value="<%= t.name %>" <%= p.teamB === t.name ? 'selected' : '' %>><%= t.name %> (<%= t.points %> ن)</option>
                                <% }); } %>
                              </select>
                            <% } else if (p.teamB) { %>
                              <span style="display:inline-flex;align-items:center;gap:6px;">
                                <img src="/flags/<%= teamFlags[p.teamB]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" style="width:18px;height:12px;border-radius:2px;">
                                <%= p.teamB %>
                                <% if (p.teamB_auto) { %><span style="font-size:0.65rem;color:#16a34a;">(تلقائي)</span><% } %>
                              </span>
                            <% } else { %>
                              <span style="color:var(--text-secondary);">—</span>
                            <% } %>
                          </td>
                          <td style="padding:10px 12px;font-size:0.78rem;color:var(--text-secondary);">
                            <% if (p.slot.winnerTo) { %><%= p.slot.winnerTo %> (<%= p.slot.side === 'teamA' ? 'طرف أول' : 'طرف ثاني' %>)<% } %>
                          </td>
                        </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </form>

                  <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
                    <button type="submit" form="seeding-form" class="db-btn db-btn-approve" style="padding:10px 24px;font-size:0.9rem;">
                      حفظ التوزيع
                    </button>
                    <% if (bestThirds && bestThirds.length > 0) { %>
                      <form method="POST" action="/admin/confirm-round32" style="margin:0;display:inline;" onsubmit="return confirm('تأكيد اعتماد دور الـ32؟\n\nبعد الاعتماد:\n• سيتم حفظ جميع مواجهات دور الـ32\n• ستنتقل الفرق تلقائياً في الأدوار التالية\n• لا يمكن تعديل توزيع الثوالث بعد الاعتماد')">
                        <button type="submit" class="db-btn" style="padding:10px 24px;font-size:0.9rem;background:#7c3aed;color:#fff;border:none;border-radius:10px;cursor:pointer;">
                          اعتماد دور الـ 32
                        </button>
                      </form>
                    <% } %>
                  </div>

                <!-- قائمة أفضل 8 ثوالث -->
                <% if (bestThirds && bestThirds.length > 0) { %>
                <div style="margin-top:20px;padding:14px;background:var(--bg);border-radius:10px;">
                  <div style="font-weight:700;font-size:0.85rem;margin-bottom:10px;">أفضل 8 ثوالث (<%= bestThirds.length %>):</div>
                  <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <% bestThirds.forEach(function(t, i) { %>
                    <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface);border-radius:20px;font-size:0.8rem;border:1px solid var(--border);">
                      <img src="/flags/<%= teamFlags[t.name]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" style="width:16px;height:11px;border-radius:2px;">
                      <%= i + 1 %>. <%= t.name %>
                      <span style="color:var(--text-secondary);font-size:0.7rem;"><%= t.points %> ن</span>
                    </span>
                    <% }); %>
                  </div>
                </div>
                <% } %>

              <% } else { %>
                <div style="padding:20px;text-align:center;color:var(--text-secondary);">
                  <% if (!bestThirds || bestThirds.length === 0) { %>
                    لم تكتمل مباريات دور المجموعات بعد. يجب احتساب ترتيب المجموعات أولاً.
                  <% } else { %>
                    لا توجد مباريات دور الـ32. يرجى التأكد من إنشاء المباريات.
                  <% } %>
                </div>
              <% } %>
            </div>

          <% } else { %>

            <!-- ---- تم الاعتماد ---- -->
            <div class="card section-card">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                <span style="background:#16a34a;color:#fff;padding:4px 14px;border-radius:20px;font-size:0.8rem;font-weight:700;">✓ تم اعتماد دور الـ32</span>
                <span style="font-size:0.85rem;color:var(--text-secondary);">جميع المواجهات والمسارات محفوظة</span>
              </div>

              <!-- مسار الأدوار الإقصائية -->
              <% if (bracketStatus && bracketStatus.rounds) { %>
                <% var roundKeys = Object.keys(bracketStatus.rounds).sort(); %>
                <% roundKeys.forEach(function(rk) { %>
                  <% var rd = bracketStatus.rounds[rk]; %>
                  <div style="margin-bottom:20px;">
                    <div style="font-weight:700;font-size:0.9rem;margin-bottom:10px;color:var(--primary);"><%= rd.name %></div>
                    <div style="overflow-x:auto;">
                      <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
                        <thead>
                          <tr style="background:var(--bg);">
                            <th style="padding:8px 10px;text-align:right;">المباراة</th>
                            <th style="padding:8px 10px;text-align:right;">الفريق A</th>
                            <th style="padding:8px 10px;text-align:right;">الفريق B</th>
                            <th style="padding:8px 10px;text-align:right;">الفائز</th>
                            <th style="padding:8px 10px;text-align:right;">يتأهل إلى</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% rd.matches.forEach(function(m) { %>
                          <tr style="border-bottom:1px solid var(--border);">
                            <td style="padding:8px 10px;font-weight:700;font-size:0.75rem;"><%= m.match_label || '—' %></td>
                            <td style="padding:8px 10px;">
                              <img src="/flags/<%= teamFlags[m.teamA]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" style="width:16px;height:11px;border-radius:2px;">
                              <%= m.teamA %>
                            </td>
                            <td style="padding:8px 10px;">
                              <img src="/flags/<%= teamFlags[m.teamB]||'unknown' %>.png" onerror="this.src='/flags/unknown.png'" style="width:16px;height:11px;border-radius:2px;">
                              <%= m.teamB %>
                            </td>
                            <td style="padding:8px 10px;">
                              <% if (m.actual_winner) { %>
                                <span style="color:#16a34a;font-weight:700;"><%= m.actual_winner %></span>
                              <% } else { %>
                                <span style="color:var(--text-secondary);">—</span>
                              <% } %>
                            </td>
                            <td style="padding:8px 10px;font-size:0.75rem;color:var(--text-secondary);">
                              <% if (m.winner_to_match_id) { %>
                                <%= m.winner_to_side === 'teamA' ? 'طرف أول' : 'طرف ثاني' %> ← م<%= m.winner_to_match_id %>
                              <% } else { %>
                                —
                              <% } %>
                            </td>
                          </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                <% }); %>
              <% } %>

              <div style="margin-top:16px;">
                <form method="POST" action="/admin/rebuild-knockout" style="margin:0;" onsubmit="return confirm('تحذير! إعادة بناء الأدوار الإقصائية:\n\n• سيتم حذف جميع نتائج المباريات الإقصائية\n• سيتم إعادة تعيين جميع المواجهات إلى الوضع الافتراضي\n• سيتم إلغاء اعتماد دور الـ32\n• لن تتأثر مباريات المجموعات أو التوقعات\n\nهل أنت متأكد؟')">
                  <button type="submit" class="db-btn" style="padding:10px 20px;font-size:0.85rem;background:#dc2626;color:#fff;border:none;border-radius:10px;cursor:pointer;">
                    إعادة بناء الأدوار الإقصائية
                  </button>
                </form>
              </div>
            </div>

          <% } %>
        </div>

        <!-- ===== TAB: الترتيب ===== -->
        <div class="db-panel <%= activeTab==='leaderboard'?'active':'' %>" id="panel-leaderboard">
          <div class="card section-card">
            <div style="font-size:0.78rem;color:var(--text-secondary);padding:8px 12px;margin-bottom:8px;background:rgba(251,191,36,0.08);border-radius:10px;border:1px solid rgba(251,191,36,0.2);">
              ⓘ يتم احتساب المباريات الفائتة ابتداءً من مباراة الأرجنتين × الجزائر (17 يونيو) بسبب استئناف المسابقة بعد فقدان البيانات السابقة.<br>
              إجمالي المباريات المطلوبة للاحتساب: <strong><%= lockedPublishedMatchCount || 0 %></strong>
            </div>
            <table>
              <thead>
                <tr><th>#</th><th>الاسم</th><th>المعرف</th><th>النقاط</th><th>التزام</th><th>التوقعات المفقودة</th></tr>
              </thead>
              <tbody>
                <% leaderboard.forEach(function(player, index) {
                  var mp = player.missed_predictions || 0;
                  var mpClass = mp === 0 ? 'mp-green' : (mp <= 2 ? 'mp-yellow' : 'mp-red');
                  var mpLabel = mp === 0 ? '0 ✅' : mp + (mp <= 2 ? ' 🟡' : ' 🔴');
                  var commit = player.commitment_rate != null ? player.commitment_rate : (player.total_locked_matches > 0 ? Math.round(((player.total_locked_matches - mp) / player.total_locked_matches) * 100) : 100);
                  var playerPredCount = player.total_locked_matches > 0 ? player.total_locked_matches - mp : 0;
                %>
                <tr>
                  <td><strong><%= index + 1 %></strong></td>
                  <td><%= player.name %></td>
                  <td style="color:var(--text-secondary);font-size:0.85rem;">@<%= player.username %></td>
                  <td><strong style="color:var(--primary);"><%= player.total %></strong></td>
                  <td><%= commit %>%</td>
                  <td>
                    <span title="توقعاته: <%= playerPredCount %>/<%= player.total_locked_matches || 0 %>" class="mp-badge <%= mpClass %>" style="cursor:<%= mp>0?'pointer':'default' %>;" onclick="<%= mp>0 ? 'showMissedPredictions(' + JSON.stringify(player.name) + ',' + JSON.stringify(player.missed_match_names) + ')' : '' %>"><%= mpLabel %></span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Missed Predictions Modal -->
        <div id="missed-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);overflow-y:auto;padding:20px;" onclick="if(event.target===this)closeMissedModal()">
          <div style="max-width:420px;margin:0 auto;background:var(--surface);border-radius:18px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.4);">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
              <span id="missed-modal-title" style="font-weight:800;font-size:0.95rem;"></span>
              <button onclick="closeMissedModal()" style="background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer;line-height:1;">&#x2715;</button>
            </div>
            <div id="missed-modal-body" style="display:flex;flex-direction:column;gap:8px;"></div>
          </div>
        </div>

        <!-- ===== TAB: الأخبار ===== -->
        <div class="db-panel <%= activeTab==='news'?'active':'' %>" id="panel-news">
          <div class="card section-card" style="margin-bottom:16px;">
            <div style="font-weight:800;font-size:0.95rem;margin-bottom:14px;">إضافة خبر جديد</div>
            <form method="POST" action="/admin/news/add" enctype="multipart/form-data" class="news-add-form">
              <div class="news-form-row">
                <input type="text" name="title" placeholder="عنوان الخبر *" required class="news-input">
              </div>
              <div class="news-form-row">
                <textarea name="body" placeholder="نص الخبر *" required rows="3" class="news-input news-textarea"></textarea>
              </div>
              <div class="news-form-row news-form-bottom">
                <label class="news-file-label">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span id="news-file-name">اختر صورة (اختياري)</span>
                  <input type="file" name="image" accept="image/*" style="display:none" onchange="document.getElementById('news-file-name').textContent=this.files[0]?this.files[0].name:'اختر صورة'">
                </label>
                <label class="news-breaking-label">
                  <input type="checkbox" name="breaking"> عاجل
                </label>
                <button type="submit" class="btn-save" style="margin-right:auto;">نشر الخبر</button>
              </div>
            </form>
          </div>

          <!-- قائمة الأخبار الحالية -->
          <div class="card section-card">
            <div style="font-weight:800;font-size:0.95rem;margin-bottom:14px;">الأخبار المنشورة (<%= newsItems.length %>)</div>
            <% if (newsItems.length === 0) { %>
              <p style="color:var(--text-secondary);font-size:0.85rem;">لا توجد أخبار بعد</p>
            <% } else { %>
              <div class="news-list-admin">
                <% newsItems.forEach(function(item, nidx) { %>
                <div class="news-admin-row">
                  <% if (item.image_path) { %>
                  <img src="<%= item.image_path %>" class="news-admin-img" onerror="this.style.display='none'">
                  <% } %>
                  <div class="news-admin-body">
                    <div class="news-admin-title">
                      <% if (item.breaking) { %><span class="db-tab-badge" style="background:#ef4444;">عاجل</span> <% } %>
                      <%= item.title %>
                    </div>
                    <p class="news-admin-excerpt"><%= item.body.length>120 ? item.body.slice(0,120)+'...' : item.body %></p>
                    <span style="font-size:0.72rem;color:var(--text-secondary);"><%= new Date(item.created_at).toLocaleDateString('ar-EG',{year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                    <% var rs = newsReadStats && newsReadStats[item.id]; if (rs) { %>
                    <div style="display:flex;gap:12px;margin-top:8px;flex-wrap:wrap;">
                      <span style="font-size:0.72rem;color:var(--text-secondary);">المشاركون: <strong style="color:var(--text);"><%= rs.total %></strong></span>
                      <span style="font-size:0.72rem;color:#22c55e;">قرأ: <strong><%= rs.readCount %></strong></span>
                      <span style="font-size:0.72rem;color:#ef4444;">لم يقرأ: <strong><%= rs.unreadCount %></strong></span>
                      <span style="font-size:0.72rem;color:var(--primary);">نسبة القراءة: <strong><%= rs.readRate %>%</strong></span>
                    </div>
                    <div style="margin-top:6px;">
                      <button class="db-btn" style="padding:3px 10px;font-size:0.7rem;background:transparent;border:1px solid var(--border);border-radius:8px;cursor:pointer;color:var(--text-secondary);font-weight:600;" onclick="toggleNewsReaders(<%= item.id %>)">📊 عرض التفاصيل</button>
                      <div id="news-readers-<%= item.id %>" style="display:none;margin-top:6px;font-size:0.78rem;">
                        <div style="display:flex;gap:20px;flex-wrap:wrap;">
                          <div>
                            <div style="font-weight:700;color:#22c55e;margin-bottom:4px;">✅ قرأ الخبر</div>
                            <div id="news-readers-ok-<%= item.id %>">جاري التحميل...</div>
                          </div>
                          <div>
                            <div style="font-weight:700;color:#ef4444;margin-bottom:4px;">❌ لم يقرأ</div>
                            <div id="news-readers-no-<%= item.id %>">جاري التحميل...</div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <% } %>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0;">
                    <button class="db-btn db-btn-edit-news" style="padding:5px 10px;font-size:0.75rem;background:var(--primary);color:#000;border:none;border-radius:8px;cursor:pointer;font-weight:700;"
                      data-idx="<%= nidx %>">
                      تعديل
                    </button>
                    <form method="POST" action="/admin/news/delete/<%= item.id %>" style="margin:0;">
                      <button type="submit" class="db-btn db-btn-delete" onclick="return confirm('حذف هذا الخبر؟')" style="padding:5px 10px;font-size:0.75rem;width:100%;">حذف</button>
                    </form>
                  </div>
                </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- ===== TAB: التعليقات ===== -->
        <div class="db-panel <%= activeTab==='comments'?'active':'' %>" id="panel-comments">
          <div class="card section-card">
            <h2>إدارة التعليقات</h2>
            <p>إظهار، إخفاء، أو حذف تعليقات المتسابقين على الأخبار.</p>
            <% if (!allComments || allComments.length === 0) { %>
              <p style="color:var(--text-secondary);font-size:0.85rem;margin-top:12px;">لا توجد تعليقات بعد</p>
            <% } else { %>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:14px;">
                <% allComments.forEach(function(c) { %>
                <div style="display:flex;align-items:center;gap:10px;padding:12px;border-radius:12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);">
                  <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                      <span style="font-weight:800;font-size:0.85rem;color:#D4AF37;"><%= c.user_name %></span>
                      <span style="font-size:0.7rem;color:var(--text-secondary);"><%= new Date(c.created_at).toLocaleString('ar-EG') %></span>
                      <% if (!c.visible) { %><span style="font-size:0.7rem;padding:1px 6px;border-radius:6px;background:#ef4444;color:#fff;">مخفي</span><% } %>
                      <span style="font-size:0.7rem;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:180px;"><%= c.news_title %></span>
                    </div>
                    <div style="font-size:0.82rem;color:var(--text);margin-top:4px;line-height:1.5;"><%= c.body %></div>
                  </div>
                  <div style="display:flex;gap:4px;flex-shrink:0;">
                    <% if (c.visible) { %>
                    <form method="POST" action="/admin/comments/hide/<%= c.id %>"><button type="submit" style="padding:5px 10px;border-radius:8px;border:1px solid #f59e0b;background:transparent;color:#f59e0b;font-size:0.75rem;font-weight:700;cursor:pointer;font-family:inherit;">إخفاء</button></form>
                    <% } else { %>
                    <form method="POST" action="/admin/comments/show/<%= c.id %>"><button type="submit" style="padding:5px 10px;border-radius:8px;border:1px solid #22c55e;background:transparent;color:#22c55e;font-size:0.75rem;font-weight:700;cursor:pointer;font-family:inherit;">إظهار</button></form>
                    <% } %>
                    <form method="POST" action="/admin/comments/delete/<%= c.id %>" onsubmit="return confirm('حذف التعليق؟')"><button type="submit" style="padding:5px 10px;border-radius:8px;border:1px solid #ef4444;background:transparent;color:#ef4444;font-size:0.75rem;font-weight:700;cursor:pointer;font-family:inherit;">حذف</button></form>
                  </div>
                </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- ===== TAB: التحدي ===== -->
        <div class="db-panel <%= activeTab==='challenge'?'active':'' %>" id="panel-challenge">
          <div class="card section-card">
            <div style="font-weight:800;font-size:0.95rem;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="color:var(--primary)"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
              </svg>
              إدارة لعبة التحدي
            </div>

            <!-- Current Config -->
            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
              <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;flex:1;min-width:150px;">
                <div style="font-size:0.75rem;color:var(--text-secondary);margin-bottom:2px;">حالة التحدي</div>
                <div style="font-weight:800;font-size:1rem;color:<%= config.open ? '#22c55e' : '#ef4444' %>"><%= config.open ? 'مفتوح' : 'مغلق' %></div>
              </div>
              <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;flex:1;min-width:150px;">
                <div style="font-size:0.75rem;color:var(--text-secondary);margin-bottom:2px;">الإغلاق</div>
                <div style="font-weight:800;font-size:0.9rem;"><%= config.deadline ? new Date(config.deadline).toLocaleString('ar-SA') : 'غير محدد' %></div>
              </div>
            </div>

            <!-- Set Deadline -->
            <form method="POST" action="/admin/challenge/deadline" style="margin-bottom:12px;">
              <label style="font-size:0.82rem;font-weight:700;display:block;margin-bottom:4px;">موعد إغلاق التحدي</label>
              <div style="display:flex;gap:6px;">
                <input type="datetime-local" name="deadline" required style="flex:1;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:0.85rem;">
                <button type="submit" class="db-btn db-btn-approve">حفظ</button>
              </div>
            </form>

            <!-- Open/Close -->
            <div style="display:flex;gap:6px;margin-bottom:16px;">
              <form method="POST" action="/admin/challenge/open">
                <button type="submit" class="db-btn db-btn-approve" <%= config.open ? 'disabled style="opacity:0.5"' : '' %>>فتح التحدي</button>
              </form>
              <form method="POST" action="/admin/challenge/close">
                <button type="submit" class="db-btn db-btn-delete" <%= !config.open ? 'disabled style="opacity:0.5"' : '' %>>إغلاق التحدي</button>
              </form>
            </div>

            <!-- Auto-Extracted Results (قراءة فقط) -->
            <div style="margin-bottom:16px;">
              <label style="font-size:0.82rem;font-weight:700;display:block;margin-bottom:8px;">المنتخبات المتأهلة (مستخرجة تلقائياً من النتائج)</label>

              <% 
                var resultsByRound = {};
                (challengeResults || []).forEach(function(r) {
                  if (!resultsByRound[r.round]) resultsByRound[r.round] = [];
                  resultsByRound[r.round].push(r.team);
                });
                var rounds = [
                  { key: 'qf', label: 'دور الـ8' },
                  { key: 'sf', label: 'دور الـ4' },
                  { key: 'finalists', label: 'طرفا النهائي' },
                  { key: 'champion', label: 'البطل' }
                ];
              %>

              <% rounds.forEach(function(rr) { %>
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:8px 12px;background:var(--bg);border-radius:8px;border:1px solid var(--border);">
                <span style="font-size:0.78rem;font-weight:700;min-width:70px;"><%= rr.label %>:</span>
                <div style="display:flex;flex-wrap:wrap;gap:4px;flex:1;">
                  <% if (resultsByRound[rr.key] && resultsByRound[rr.key].length > 0) { %>
                    <% resultsByRound[rr.key].forEach(function(t) { %>
                    <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);border-radius:20px;font-size:0.78rem;font-weight:700;">
                      <img src="/flags/<%= (teamFlags && teamFlags[t]) || 'unknown' %>.png" style="width:18px;height:13px;object-fit:cover;border-radius:2px;" onerror="this.style.display='none'">
                      <%= t %>
                    </span>
                    <% }) %>
                  <% } else { %>
                    <span style="font-size:0.75rem;color:var(--text-secondary);font-style:italic;">لم تكتمل هذه المرحلة بعد</span>
                  <% } %>
                </div>
              </div>
              <% }) %>
            </div>

            <!-- Auto-Calculate + Recalculate Buttons -->
            <div style="display:flex;gap:6px;margin-bottom:16px;">
              <form method="POST" action="/admin/challenge/auto-results">
                <button type="submit" class="db-btn" style="background:#6366f1;color:#fff;font-weight:800;">🔄 إعادة احتساب المتأهلين</button>
              </form>
              <form method="POST" action="/admin/challenge/calculate">
                <button type="submit" class="db-btn" style="background:#d4af37;color:#fff;font-weight:800;">🧮 احسب نقاط التحدي</button>
              </form>
            </div>

            <!-- Participants List -->
            <div style="margin-top:20px;">
              <div style="font-weight:700;font-size:0.85rem;margin-bottom:8px;">المشاركون (<%= (challengePicks||[]).length %>):</div>
              <div style="display:flex;flex-direction:column;gap:6px;">
                <% (challengePicks||[]).forEach(function(p, pi) { %>
                <div class="db-pred-match">
                  <div class="db-pred-match-header" onclick="this.parentElement.classList.toggle('open')">
                    <div class="db-pred-match-title" style="font-size:0.85rem;">
                      <span style="font-weight:800;"><%= p.user_name %></span>
                    </div>
                    <div class="db-pred-match-right">
                      <% if (p.qf) { %><span style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">QF: <%= p.qf.length %></span><% } %>
                      <% if (p.sf) { %><span style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">SF: <%= p.sf.length %></span><% } %>
                      <span class="db-pred-chevron">▼</span>
                    </div>
                  </div>
                  <div class="db-pred-body" style="padding:12px 14px;">
                    <% if (p.qf && Array.isArray(p.qf)) { %>
                    <div style="margin-bottom:8px;">
                      <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">دور الـ8 (5 نقاط لكل منتخب):</div>
                      <div style="display:flex;flex-wrap:wrap;gap:4px;">
                        <% p.qf.forEach(function(t) { %>
                        <span style="padding:2px 8px;background:rgba(212,175,55,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                        <% }) %>
                      </div>
                    </div>
                    <% } %>
                    <% if (p.sf && Array.isArray(p.sf)) { %>
                    <div style="margin-bottom:8px;">
                      <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">دور الـ4 (10 نقاط لكل منتخب):</div>
                      <div style="display:flex;flex-wrap:wrap;gap:4px;">
                        <% p.sf.forEach(function(t) { %>
                        <span style="padding:2px 8px;background:rgba(212,175,55,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                        <% }) %>
                      </div>
                    </div>
                    <% } %>
                    <% if (p.finalists && Array.isArray(p.finalists)) { %>
                    <div style="margin-bottom:8px;">
                      <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">طرفا النهائي (15 نقطة لكل منتخب):</div>
                      <div style="display:flex;flex-wrap:wrap;gap:4px;">
                        <% p.finalists.forEach(function(t) { %>
                        <span style="padding:2px 8px;background:rgba(212,175,55,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                        <% }) %>
                      </div>
                    </div>
                    <% } %>
                    <% if (p.champion) { %>
                    <div>
                      <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">البطل (20 نقطة):</div>
                      <span style="padding:2px 10px;background:rgba(212,175,55,0.15);border-radius:6px;font-size:0.82rem;font-weight:800;color:#d4af37;"><%= p.champion %></span>
                    </div>
                    <% } %>
                  </div>
                </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <!-- ===== TAB: الإعدادات ===== -->
        <div class="db-panel <%= activeTab==='settings'?'active':'' %>" id="panel-settings">
          <div class="card section-card" style="max-width:480px;">
            <div style="font-weight:800;font-size:0.95rem;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="color:var(--primary)"><path d="M12 15c1.66 0 2.99-1.34 2.99-3L15 6c0-1.66-1.34-3-3-3S9 4.34 9 6v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 15 6.7 12H5c0 3.42 2.72 6.23 6 6.72V22h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg>
              تغيير كلمة المرور
            </div>
            <form method="POST" action="/admin/change-password" style="display:flex;flex-direction:column;gap:14px;">
              <div>
                <label style="display:block;font-size:0.8rem;font-weight:700;color:var(--text-secondary);margin-bottom:6px;">كلمة المرور الحالية</label>
                <input type="password" name="currentPassword" required style="width:100%;padding:12px;border:1.5px solid var(--border);border-radius:10px;font-size:0.9rem;background:var(--surface);" placeholder="••••••••">
              </div>
              <div>
                <label style="display:block;font-size:0.8rem;font-weight:700;color:var(--text-secondary);margin-bottom:6px;">كلمة المرور الجديدة</label>
                <input type="password" name="newPassword" required minlength="6" style="width:100%;padding:12px;border:1.5px solid var(--border);border-radius:10px;font-size:0.9rem;background:var(--surface);" placeholder="••••••••">
                <small style="color:var(--text-secondary);font-size:0.7rem;">يجب أن تكون 6 أحرف على الأقل</small>
              </div>
              <div>
                <label style="display:block;font-size:0.8rem;font-weight:700;color:var(--text-secondary);margin-bottom:6px;">تأكيد كلمة المرور الجديدة</label>
                <input type="password" name="confirmPassword" required style="width:100%;padding:12px;border:1.5px solid var(--border);border-radius:10px;font-size:0.9rem;background:var(--surface);" placeholder="••••••••">
              </div>
              <button type="submit" class="db-btn db-btn-approve" style="margin-top:6px;padding:12px;font-size:0.9rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" style="margin-left:6px;"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                حفظ التغييرات
              </button>
            </form>
          </div>
        </div>

      </section>
    </main>
  </div>

  <!-- Edit News Modal -->
  <div id="edit-news-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);overflow-y:auto;padding:20px;" onclick="if(event.target===this)closeEditNews()">
    <div style="max-width:480px;margin:0 auto;background:var(--surface);border-radius:18px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.4);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
        <span style="font-weight:800;font-size:0.95rem;">تعديل الخبر</span>
        <button onclick="closeEditNews()" style="background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer;line-height:1;">&#x2715;</button>
      </div>
      <form id="edit-news-form" method="POST" enctype="multipart/form-data" class="news-add-form">
        <div class="news-form-row">
          <input type="text" id="en-title" name="title" placeholder="عنوان الخبر *" required class="news-input">
        </div>
        <div class="news-form-row">
          <textarea id="en-body" name="body" placeholder="نص الخبر *" required rows="4" class="news-input news-textarea"></textarea>
        </div>
        <div id="en-current-img-wrap" style="display:none;margin-bottom:4px;">
          <img id="en-current-img" src="" style="max-height:80px;border-radius:8px;" onerror="this.parentElement.style.display='none'">
          <span style="font-size:0.75rem;color:var(--text-secondary);display:block;margin-top:4px;">الصورة الحالية — اختر صورة جديدة لاستبدالها</span>
        </div>
        <div class="news-form-row news-form-bottom">
          <label class="news-file-label">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span id="en-file-name">اختر صورة جديدة</span>
            <input type="file" name="image" accept="image/*" style="display:none" onchange="document.getElementById('en-file-name').textContent=this.files[0]?this.files[0].name:'اختر صورة جديدة'">
          </label>
          <label class="news-breaking-label">
            <input type="checkbox" id="en-breaking" name="breaking"> عاجل
          </label>
          <button type="submit" class="btn-save" style="margin-right:auto;">حفظ التعديل</button>
        </div>
      </form>
    </div>
  </div>

  <script type="application/json" id="admin-news-json"><%- JSON.stringify(newsItems.map(function(n){ return { id: n.id, title: n.title, body: n.body, img: n.image_path||'', brk: !!n.breaking }; })) %></script>
  <script>
    var ADMIN_NEWS_DATA = JSON.parse(document.getElementById('admin-news-json').textContent);

    document.querySelectorAll('.db-btn-edit-news').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(this.dataset.idx, 10);
        var n = ADMIN_NEWS_DATA[idx];
        if (!n) return;
        document.getElementById('en-title').value = n.title;
        document.getElementById('en-body').value = n.body;
        document.getElementById('en-breaking').checked = n.brk;
        document.getElementById('edit-news-form').action = '/admin/news/edit/' + n.id;
        var imgWrap = document.getElementById('en-current-img-wrap');
        var imgEl = document.getElementById('en-current-img');
        if (n.img) { imgEl.src = n.img; imgWrap.style.display = 'block'; }
        else { imgWrap.style.display = 'none'; }
        document.getElementById('en-file-name').textContent = 'اختر صورة جديدة';
        document.getElementById('edit-news-modal').style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    });
    function closeEditNews() {
      document.getElementById('edit-news-modal').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeEditNews(); });

    function toggleNewsReaders(newsId) {
      var el = document.getElementById('news-readers-' + newsId);
      if (!el) return;
      if (el.style.display !== 'none') { el.style.display = 'none'; return; }
      el.style.display = 'block';
      var okEl = document.getElementById('news-readers-ok-' + newsId);
      var noEl = document.getElementById('news-readers-no-' + newsId);
      if (!okEl || !noEl) return;
      okEl.textContent = 'جاري التحميل...';
      noEl.textContent = 'جاري التحميل...';
      fetch('/api/news/readers/' + newsId)
        .then(function(r){ return r.json(); })
        .then(function(data){
          okEl.innerHTML = data.readers && data.readers.length > 0
            ? data.readers.map(function(u){ return '<div>✅ ' + u.name + '</div>'; }).join('')
            : '<div style="color:#94a3b8;">لا يوجد</div>';
          noEl.innerHTML = data.unreadUsers && data.unreadUsers.length > 0
            ? data.unreadUsers.map(function(u){ return '<div>❌ ' + u.name + '</div>'; }).join('')
            : '<div style="color:#94a3b8;">الكل قرأ الخبر</div>';
        })
        .catch(function(){
          okEl.textContent = 'فشل التحميل';
          noEl.textContent = 'فشل التحميل';
        });
    }

    function dbTab(name, btn) {
      document.querySelectorAll('.db-panel').forEach(function(p){ p.classList.remove('active'); });
      document.querySelectorAll('.db-tab').forEach(function(t){ t.classList.remove('active'); });
      document.getElementById('panel-' + name).classList.add('active');
      btn.classList.add('active');
    }

    var flagMap = <%- JSON.stringify(teamFlags) %>;

    function updateKoFlag(selectEl, imgId) {
      var team = selectEl.value;
      var img = document.getElementById(imgId);
      if (!img) return;
      var code = flagMap[team] || 'unknown';
      img.src = '/flags/' + code + '.png';
      img.onerror = function(){ this.src='/flags/unknown.png'; };
    }

    function pgSwitchRoundTab(ri, btn) {
      document.querySelectorAll('.pg-round-panel-main').forEach(function(p){ p.classList.remove('active'); });
      document.querySelectorAll('#panel-predictions > .card > .pg-group-tabs .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('pg-round-panel-' + ri);
      if (panel) panel.classList.add('active');
      btn.classList.add('active');
    }

    function pgSwitchGroup(gi, btn) {
      document.querySelectorAll('.pg-group-panel').forEach(function(p){ p.classList.remove('active'); });
      document.querySelectorAll('#panel-predictions > .card > .pg-group-tabs .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('pg-panel-' + gi);
      if (panel) panel.classList.add('active');
      btn.classList.add('active');
    }

    var resActiveDateFilter = 'all';

    function resDateFilter(filter, btn) {
      resActiveDateFilter = filter;
      document.querySelectorAll('#res-date-filters .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      var activePanel = document.querySelector('#panel-results .pg-round-panel-main.active');
      if (!activePanel) return;
      var todayKey = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
      var d = new Date();
      var targetKey;
      if (filter === 'today') {
        targetKey = todayKey;
      } else if (filter === 'yesterday') {
        d.setDate(d.getDate() - 1); targetKey = d.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
      } else if (filter === 'tomorrow') {
        d.setDate(d.getDate() + 1); targetKey = d.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
      }
      activePanel.querySelectorAll('.db-result-card').forEach(function(card){
        if (filter === 'all') { card.style.display = ''; }
        else { card.style.display = (card.getAttribute('data-rs-date') === targetKey) ? '' : 'none'; }
      });
    }

    function resSwitchRoundTab(ri, btn) {
      document.querySelectorAll('#panel-results .pg-round-panel-main').forEach(function(p){ p.classList.remove('active'); });
      document.querySelectorAll('#res-round-tabs .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      document.querySelectorAll('#res-date-filters .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('res-round-panel-' + ri);
      if (panel) panel.classList.add('active');
      btn.classList.add('active');
      // Reset date filter to all on round switch
      resActiveDateFilter = 'all';
      var allBtn = document.querySelector('#res-date-filters .pg-gtab[data-res-date="all"]');
      if (allBtn) allBtn.classList.add('active');
      if (panel) panel.querySelectorAll('.db-result-card').forEach(function(c){ c.style.display = ''; });
    }

    function resSwitchGroup(gi, btn) {
      document.querySelectorAll('#panel-results .pg-group-panel').forEach(function(p){ p.classList.remove('active'); });
      document.querySelectorAll('#res-group-tabs .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('res-panel-' + gi);
      if (panel) panel.classList.add('active');
      btn.classList.add('active');
    }

    function resSwitchRound(gi, r, btn) {
      var panel = document.getElementById('res-panel-' + gi);
      if (!panel) return;
      panel.querySelectorAll('.res-round-panel').forEach(function(p){ p.style.display='none'; });
      panel.querySelectorAll('.pg-rfbtn').forEach(function(b){ b.classList.remove('active'); });
      var rp = document.getElementById('res-rp-' + gi + '-' + r);
      if (rp) rp.style.display = 'block';
      btn.classList.add('active');
    }

    function resSwitchKo(ki, btn) {
      document.querySelectorAll('.res-ko-panel').forEach(function(p){ p.style.display='none'; });
      document.querySelectorAll('#panel-results .pg-ko-section .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('res-ko-' + ki);
      if (panel) panel.style.display = 'block';
      btn.classList.add('active');
    }

    function pgSwitchKo(ki, btn) {
      document.querySelectorAll('.pg-ko-panel').forEach(function(p){ p.style.display='none'; });
      document.querySelectorAll('.pg-ko-section .pg-gtab').forEach(function(t){ t.classList.remove('active'); });
      var panel = document.getElementById('pg-ko-' + ki);
      if (panel) panel.style.display = 'block';
      btn.classList.add('active');
    }

    function pgSwitchRound(gi, r, btn) {
      var panel = document.getElementById('pg-panel-' + gi);
      if (!panel) return;
      panel.querySelectorAll('.pg-round-panel').forEach(function(p){ p.style.display='none'; });
      panel.querySelectorAll('.pg-rfbtn').forEach(function(b){ b.classList.remove('active'); });
      var rp = document.getElementById('pg-rp-' + gi + '-' + r);
      if (rp) rp.style.display = 'block';
      btn.classList.add('active');
    }

    var predData = JSON.parse(document.getElementById('pred-data').textContent);
    var predApprovedUsers = predData.approvedUsers || [];
    var predMap = {};
    (predData.matches || []).forEach(function(m){ predMap[m.id] = m; });

    var pmTimer = null;

    function openPredModal(matchId) {
      var m = predMap[matchId];
      if (!m) return;
      var title = document.getElementById('predModalTitle');
      var body = document.getElementById('predModalBody');
      var footer = document.getElementById('predModalFooter');
      title.innerHTML = '<img src="/flags/'+m.flagA+'.png" onerror="this.src=\'/flags/unknown.png\'" class="pm-flag"> '+m.teamA+' <span class="pm-vs">VS</span> '+m.teamB+' <img src="/flags/'+m.flagB+'.png" onerror="this.src=\'/flags/unknown.png\'" class="pm-flag">';

      // Countdown
      var now = Date.now();
      var lockMs = m.lockTime - now;
      var countdownHtml = '<div class="pm-countdown" id="pmCountdown">';
      if (lockMs <= 0) {
        countdownHtml += '⏳ تم إغلاق التوقع';
      } else {
        countdownHtml += '⏳ يغلق التوقع بعد: <span id="pmCountdownVal">'+msToHms(lockMs)+'</span>';
      }
      countdownHtml += '</div>';

      // Build lists
      var predById = {};
      (m.preds || []).forEach(function(p){ predById[p.userId] = p; });
      var withPred = [], withoutPred = [];
      predApprovedUsers.forEach(function(u){
        if (predById[u.id]) { withPred.push(u); }
        else { withoutPred.push(u); }
      });
      withPred.sort(function(a,b){ return (a.name||'').localeCompare(b.name||''); });
      withoutPred.sort(function(a,b){ return (a.name||'').localeCompare(b.name||''); });

      if (predApprovedUsers.length === 0) {
        body.innerHTML = countdownHtml + '<p class="pm-empty">لا يوجد متسابقون بعد</p>';
      } else {
        var html = countdownHtml;
        if (withoutPred.length > 0) {
          html += '<div style="margin-bottom:10px;padding:8px 12px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:10px;">';
          html += '<div style="font-weight:800;font-size:0.8rem;color:#ef4444;margin-bottom:6px;">⚠️ لم يسجلوا توقع ('+withoutPred.length+')</div>';
          html += '<div style="display:flex;flex-wrap:wrap;gap:4px;">';
          withoutPred.forEach(function(u){
            html += '<span style="background:rgba(239,68,68,0.12);color:#ef4444;padding:3px 8px;border-radius:6px;font-size:0.78rem;font-weight:700;">'+escHtml(u.name)+'</span>';
          });
          html += '</div></div>';
        }
        html += '<div class="pm-chips">';
        predApprovedUsers.forEach(function(u){
          var p = predById[u.id];
          var hasPred = !!p;
          html += '<form method="POST" action="/admin/save-prediction/'+matchId+'/'+u.id+'" style="display:flex;align-items:center;gap:6px;background:var(--surface-alt,#f8fafc);border:1px solid var(--border);border-radius:20px;padding:5px 12px;margin-bottom:6px;">';
          html += '<span class="pm-name" style="flex:1;">'+escHtml(u.name)+'</span>';
          html += '<input type="number" name="scoreA" value="'+(hasPred ? p.a : '')+'" min="0" max="99" style="width:36px;padding:4px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);text-align:center;font-size:0.85rem;" required>';
          html += '<span style="color:var(--text-secondary);font-weight:700;">-</span>';
          html += '<input type="number" name="scoreB" value="'+(hasPred ? p.b : '')+'" min="0" max="99" style="width:36px;padding:4px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);text-align:center;font-size:0.85rem;" required>';
          html += '<button type="submit" class="pm-save-btn" title="حفظ التوقع">💾</button>';
          if (hasPred) {
            html += '<button type="button" class="pm-del-btn" title="حذف التوقع" onclick="if(confirm(\'حذف توقع '+escHtml(u.name)+'?\')){var f=document.createElement(\'form\');f.method=\'POST\';f.action=\'/admin/delete-prediction/'+matchId+'/'+u.id+'\';f.style.display=\'none\';document.body.appendChild(f);f.submit();}">🗑</button>';
          }
          html += '</form>';
        });
        html += '</div>';
        body.innerHTML = html;
      }

      footer.innerHTML = '<form method="POST" action="/admin/toggle-predictions/'+matchId+'" style="margin:0">'+(m.visible ? '<button class="pm-btn pm-btn-hide">🔒 إخفاء التوقعات</button>' : '<button class="pm-btn pm-btn-show">👁 إظهار التوقعات</button>')+'</form>';
      document.getElementById('predModalOverlay').classList.add('open');

      // Start countdown timer
      if (pmTimer) clearInterval(pmTimer);
      if (lockMs > 0) {
        pmTimer = setInterval(function(){
          var el = document.getElementById('pmCountdownVal');
          if (!el) { clearInterval(pmTimer); pmTimer = null; return; }
          var remaining = m.lockTime - Date.now();
          if (remaining <= 0) {
            el.parentElement.innerHTML = '⏳ تم إغلاق التوقع';
            clearInterval(pmTimer); pmTimer = null;
          } else {
            el.textContent = msToHms(remaining);
          }
        }, 1000);
      }
    }

    function msToHms(ms) {
      if (ms <= 0) return '00:00:00';
      var s = Math.floor(ms / 1000);
      var h = Math.floor(s / 3600);
      s %= 3600;
      var m = Math.floor(s / 60);
      s %= 60;
      return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    }

    function escHtml(str) {
      var d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    function closePredModal() {
      document.getElementById('predModalOverlay').classList.remove('open');
      if (pmTimer) { clearInterval(pmTimer); pmTimer = null; }
    }

    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closePredModal(); });

    function clearResult(matchId) {
      var form = document.getElementById('res-form-' + matchId);
      if (!form) return;
      form.querySelector('[name="scoreA"]').value = '';
      form.querySelector('[name="scoreB"]').value = '';
      form.submit();
    }

    function dbTogglePenalty(input) {
      var form = input.closest('.db-result-form');
      if (!form) return;
      var a = parseInt(form.querySelector('[name="scoreA"]').value) || 0;
      var b = parseInt(form.querySelector('[name="scoreB"]').value) || 0;
      var penalty = form.querySelector('[name="penaltyWinner"]');
      if (penalty) {
        penalty.style.display = (a === b) ? 'inline-block' : 'none';
      }
    }
    // Activate on load
    document.addEventListener('DOMContentLoaded', function(){
      document.querySelectorAll('.db-result-form').forEach(function(form){
        var penalty = form.querySelector('[name="penaltyWinner"]');
        if (penalty) {
          var a = parseInt(form.querySelector('[name="scoreA"]').value) || 0;
          var b = parseInt(form.querySelector('[name="scoreB"]').value) || 0;
          penalty.style.display = (a === b) ? 'inline-block' : 'none';
        }
      });
    });

    function escJsStr(str) {
      if (!str) return '';
      return str.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'\\"').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function showMissedPredictions(playerName, matches) {
      document.getElementById('missed-modal-title').textContent = playerName + ' — المباريات المفقودة (' + matches.length + ')';
      var body = document.getElementById('missed-modal-body');
      if (!matches || matches.length === 0) {
        body.innerHTML = '<div style="color:var(--text-secondary);font-size:0.85rem;text-align:center;padding:10px 0;">لا توجد مباريات مفقودة</div>';
      } else {
        body.innerHTML = matches.map(function(m){
          return '<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;background:rgba(255,255,255,0.04);font-size:0.85rem;font-weight:700;color:var(--text);">' +
            '<span style="color:#ef4444;font-size:1rem;">✗</span>' +
            '<span>' + escHtml(m.teamA) + ' VS ' + escHtml(m.teamB) + '</span>' +
          '</div>';
        }).join('');
      }
      document.getElementById('missed-modal').style.display = 'block';
      document.body.style.overflow = 'hidden';
    }
    function closeMissedModal() {
      document.getElementById('missed-modal').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeMissedModal(); });
  </script>

<%- include('partials/mobile-nav', { active: 'dashboard' }) %>
</body>
</html>
