<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>الرئيسية - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'home', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

        <!-- ===== MOBILE HOME (≤860px) ===== -->
        <div class="hm2">

          <!-- Hero Header -->
          <div class="hm2-hero">
            <div class="hm2-hero-bg"></div>
            <div class="hm2-hero-top">
              <div class="hm2-logo-wrap">
                <img src="/logo.png" alt="مسابقة توقعات" class="hm2-logo">
                <div class="hm2-title">
                  <span class="hm2-title-small">مرحباً بك في</span>
                  <h1 class="hm2-title-main">مسابقة توقعات<br>كأس العالم 2026</h1>
                </div>
              </div>
            </div>
            <div class="hm2-date">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span id="todayDate">جارٍ التحميل...</span>
            </div>
            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <a href="/news" class="hm2-news-badge">
              <span>🔴</span>
              <span><%= unreadCount %> <%= unreadCount >= 3 ? 'أخبار جديدة' : 'خبر جديد' %></span>
            </a>
            <% } %>
          </div>

          <!-- Stats Cards -->
          <div class="hm2-stats">
            <div class="hm2-stat-card">
              <div class="hm2-stat-icon hm2-stat-gold">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
              </div>
              <div class="hm2-stat-num"><%= userPoints || 0 %></div>
              <div class="hm2-stat-label">نقطة</div>
              <div class="hm2-stat-sublabel">آخر مباراة متوقعة</div>
            </div>
            <div class="hm2-stat-card">
              <div class="hm2-stat-icon hm2-stat-blue">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
              </div>
              <div class="hm2-stat-num"><%= predictionsCount || 0 %></div>
              <div class="hm2-stat-label">توقع</div>
              <div class="hm2-stat-sublabel">توقعاتك المسجلة</div>
            </div>
            <div class="hm2-stat-card">
              <div class="hm2-stat-icon hm2-stat-green">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              </div>
              <div class="hm2-stat-num"><%= userRank || 0 %></div>
              <div class="hm2-stat-label">ترتيبك الآن</div>
              <div class="hm2-stat-sublabel">من بين جميع المتسابقين</div>
            </div>
            <div class="hm2-stat-card">
              <div class="hm2-stat-icon hm2-stat-purple">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              </div>
              <div class="hm2-stat-num"><%= correctPredictions || 0 %></div>
              <div class="hm2-stat-label">توقعات صحيحة</div>
              <div class="hm2-stat-sublabel">أحسنت!</div>
            </div>
          </div>

          <!-- Add Predictions Banner -->
          <div class="hm2-add-prediction">
            <div class="hm2-add-left">
              <div class="hm2-add-icon">⭐</div>
              <div class="hm2-add-text">
                <div class="hm2-add-title">أضف توقعاتك الآن</div>
                <div class="hm2-add-sub">كن جزءاً من المنافسة وتصدر الترتيب</div>
              </div>
            </div>
            <a href="/predictions" class="hm2-add-btn">
              <span>إضافة توقع جديد</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </a>
          </div>

          <!-- Next Match Section -->
          <div class="hm2-section">
            <div class="hm2-sec-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>المباراة القادمة</span>
            </div>
            <% if (upcomingMatches && upcomingMatches.length > 0) { %>
            <% var nextMatch = upcomingMatches[0]; %>
            <div class="hm2-match-card">
              <div class="hm2-match-badge"><%= nextMatch.group || '' %> - <%= nextMatch.stage || '' %></div>
              <div class="hm2-match-teams">
                <div class="hm2-match-team">
                  <img src="/flags/<%= teamFlags[nextMatch.teamB] || 'unknown' %>.png" alt="<%= nextMatch.teamB %>" class="hm2-match-flag" onerror="this.src='/flags/unknown.png'">
                  <span class="hm2-match-name"><%= nextMatch.teamB %></span>
                </div>
                <div class="hm2-match-info">
                  <div class="hm2-match-date"><%= new Date(nextMatch.start_at).toLocaleDateString('ar-SA',{weekday:'long',timeZone:'Asia/Riyadh'}) %></div>
                  <div class="hm2-match-time"><%= new Date(nextMatch.start_at).toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Asia/Riyadh'}) %></div>
                  <div class="hm2-match-stadium"><%= nextMatch.stadium || '' %></div>
                </div>
                <div class="hm2-match-team">
                  <img src="/flags/<%= teamFlags[nextMatch.teamA] || 'unknown' %>.png" alt="<%= nextMatch.teamA %>" class="hm2-match-flag" onerror="this.src='/flags/unknown.png'">
                  <span class="hm2-match-name"><%= nextMatch.teamA %></span>
                </div>
              </div>
              <a href="/predictions" class="hm2-match-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                عرض تفاصيل المباراة
              </a>
            </div>
            <% } else { %>
            <div class="hm2-empty">لا توجد مباريات قادمة</div>
            <% } %>
          </div>

          <!-- Quick Actions -->
          <div class="hm2-section">
            <div class="hm2-sec-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <span>إجراءات سريعة</span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <a href="/predictions" class="hm2-quick-btn" style="background:linear-gradient(135deg, #22c55e 0%, #16a34a 100%);color:#fff;padding:16px;border-radius:12px;text-align:center;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:8px;">
                <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                <span style="font-weight:700;font-size:0.9rem;">إضافة توقع</span>
              </a>
              <a href="/schedule" class="hm2-quick-btn" style="background:linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);color:#fff;padding:16px;border-radius:12px;text-align:center;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:8px;">
                <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
                <span style="font-weight:700;font-size:0.9rem;">جدول المباريات</span>
              </a>
            </div>
          </div>

        </div>
        <!-- ===== END MOBILE HOME ===== -->

        <!-- ===== DESKTOP HOME (≥861px) ===== -->
        <div class="mh-desktop">

        <!-- Stats Bar -->
        <div class="hm-stats">
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= predictionsCount %></span>
              <span class="hm-stat-lbl">توقعاتك المسجلة</span>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-green">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num">
                <%= lastPrediction ? (lastPrediction.points || 0) : 0 %>
              </span>
              <span class="hm-stat-lbl">نقاط آخر توقع</span>
              <% if (lastMatch) { %>
                <small style="color:var(--text-secondary);font-size:0.75rem;"><%= lastMatch.teamA %> vs <%= lastMatch.teamB %></small>
              <% } %>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-indigo">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="22" height="22"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= correctPredictions %></span>
              <span class="hm-stat-lbl">عدد التوقعات الصحيحة</span>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-red">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= userRank %></span>
              <span class="hm-stat-lbl">ترتيبك الآن</span>
            </div>
          </div>
          <div class="hm-stat-card hm-stat-highlight">
            <div class="hm-stat-icon hm-stat-gold">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= userPoints.toLocaleString('ar-EG') %></span>
              <span class="hm-stat-lbl">نقاطك الحالية</span>
            </div>
          </div>
        </div>

        <!-- Matches Section -->
        <div class="hm-section">
          <!-- Toolbar -->
          <div class="hm-toolbar">
            <div class="hm-toolbar-right">
              <span class="hm-toolbar-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                التوقعات القادمة والأكثر شعبية
              </span>
            </div>
            <div class="hm-toolbar-left">
              <button class="hm-view-btn active" id="hm-list-btn" onclick="hmSetView('list')" title="عرض القائمة">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
              </button>
              <button class="hm-view-btn" id="hm-grid-btn" onclick="hmSetView('grid')" title="عرض الشبكة">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              </button>
              <button class="hm-filter-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                تصفية المباريات
              </button>
            </div>
          </div>

          <!-- Matches Table -->
          <div class="hm-table-wrap" id="hm-matches-container">
            <table class="hm-table">
              <thead>
                <tr>
                  <th>المباراة</th>
                  <th>المجموعة</th>
                  <th>الوقت</th>
                  <th>التوقعات الكلية</th>
                  <th>توقع</th>
                </tr>
              </thead>
              <tbody>
                <% matches.forEach((item, idx) => { %>
                <%
                  const match = item.match || item;
                  const pred = item.prediction;
                  const locked = item.locked;
                  const totalPreds = '-';
                %>
                <tr class="hm-row <%= locked ? 'hm-row-locked' : '' %>">
                  <td>
                    <div class="hm-match-cell">
                      <div class="hm-match-team">
                        <div class="hm-match-flag">
                          <img src="/flags/<%= teamFlags[match.teamA] || 'unknown' %>.png" alt="<%= match.teamA %>" onerror="this.src='/flags/unknown.png'">
                        </div>
                        <span class="hm-match-name"><%= match.teamA %></span>
                      </div>
                      <div class="hm-vs">
                        <% if (match.actual_scoreA != null && match.actual_scoreB != null) { %>
                          <span class="hm-final-score"><%= match.actual_scoreA %> - <%= match.actual_scoreB %></span>
                        <% } else { %>
                          VS
                        <% } %>
                      </div>
                      <div class="hm-match-team hm-match-team-right">
                        <span class="hm-match-name"><%= match.teamB %></span>
                        <div class="hm-match-flag">
                          <img src="/flags/<%= teamFlags[match.teamB] || 'unknown' %>.png" alt="<%= match.teamB %>" onerror="this.src='/flags/unknown.png'">
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="hm-group-badge"><%= match.stage %></span>
                  </td>
                  <td>
                    <div class="hm-time-cell">
                      <span class="hm-time-text">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <%= new Date(match.start_at).toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Riyadh' }) %>
                      </span>
                    </div>
                  </td>
                  <td>
                    <span class="hm-total-preds"><%= totalPreds.toLocaleString('ar-EG') %></span>
                  </td>
                  <td>
                    <div class="hm-pred-cell">
                      <% if (locked) { %>
                        <span class="hm-locked-badge">انتهى الوقت</span>
                      <% } else { %>
                        <form method="POST" action="/predictions" class="hm-pred-form">
                          <input type="hidden" name="matchId" value="<%= match.id %>">
                          <div class="hm-score-inputs">
                            <input type="number" name="scoreA" value="<%= pred ? pred.scoreA : '' %>" min="0" placeholder="0" required class="hm-score-input">
                            <span class="hm-score-sep">-</span>
                            <input type="number" name="scoreB" value="<%= pred ? pred.scoreB : '' %>" min="0" placeholder="0" required class="hm-score-input">
                          </div>
                          <button type="submit" class="hm-save-btn">سجل توقعك</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% if (matches.length === 0) { %>
            <div class="hm-empty">
              <div class="hm-empty-icon">⚽</div>
              <div class="hm-empty-title">لا توجد مباريات متاحة</div>
              <div class="hm-empty-text">لا توجد مباريات في الوقت الحالي.</div>
            </div>
            <% } %>
          </div>
        </div>

    </div>
  </section>
    </main>
  </div>

  <script>
    // Set today's date
    document.getElementById('todayDate').textContent = new Date().toLocaleDateString('ar-SA', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });

    function hmSetView(view) {
      const container = document.getElementById('hm-matches-container');
      const listBtn = document.getElementById('hm-list-btn');
      const gridBtn = document.getElementById('hm-grid-btn');
      if (view === 'grid') {
        container.classList.add('hm-grid-view');
        gridBtn.classList.add('active');
        listBtn.classList.remove('active');
      } else {
        container.classList.remove('hm-grid-view');
        listBtn.classList.add('active');
        gridBtn.classList.remove('active');
      }
    }
  </script>
<%- include('partials/mobile-nav', { active: 'home' }) %>
</body>
</html>
