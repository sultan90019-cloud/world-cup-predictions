<!-- Fixed Menu Trigger Button (mobile only) -->
<button class="mobile-menu-trigger" data-mobile-menu-trigger aria-label="فتح القائمة">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill:#ffffff;display:block;flex-shrink:0;">
    <rect x="3" y="5" width="18" height="2" rx="1"/>
    <rect x="3" y="11" width="18" height="2" rx="1"/>
    <rect x="3" y="17" width="18" height="2" rx="1"/>
  </svg>
</button>

<!-- Drawer Overlay -->
<div class="mobile-drawer-overlay" data-mobile-drawer-overlay></div>

<!-- Right Side Drawer -->
<div class="mobile-side-drawer" data-mobile-drawer role="dialog" aria-label="القائمة الرئيسية">
  <!-- Close + User Info -->
  <div class="msd-top">
    <button class="msd-close" data-mobile-drawer-close aria-label="إغلاق القائمة">
      <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
    <div class="msd-user">
      <div class="msd-avatar">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      </div>
      <span class="msd-user-name"><%= (typeof user !== 'undefined' && user) ? (user.name || user.username || 'مستخدم') : 'مستخدم' %></span>
      <% var msdPoints = typeof totalPoints !== 'undefined' ? totalPoints : (typeof userPoints !== 'undefined' ? userPoints : null); %>
      <% if (msdPoints !== null) { %><span class="msd-user-pts"><%= msdPoints %> نقطة</span><% } %>
    </div>
  </div>

  <!-- Nav Items -->
  <nav class="msd-nav">
    <%
      var _navUser = typeof user !== 'undefined' ? user : null;
      var drawerItems = navItems.filter(function(item) {
        if (item.adminOnly && (!_navUser || _navUser.role !== 'admin')) return false;
        return true;
      });
    %>
    <% drawerItems.forEach(function(item) { %>
      <a class="msd-link <%= active === item.id ? 'msd-link-active' : '' %>" href="<%= item.url %>">
        <div class="msd-link-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <% if (item.icon === 'home') { %><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            <% } else if (item.icon === 'schedule') { %><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
            <% } else if (item.icon === 'predict') { %><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            <% } else if (item.icon === 'list') { %><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
            <% } else if (item.icon === 'trophy') { %><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
            <% } else if (item.icon === 'users') { %><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            <% } else if (item.icon === 'rules') { %><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/>
            <% } else if (item.icon === 'news') { %><path d="M22 3l-1.67 1.67L18.67 3 17 4.67 15.33 3l-1.66 1.67L12 3l-1.67 1.67L8.67 3 7 4.67 5.33 3 3.67 4.67 2 3v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V3z"/>
            <% } else if (item.icon === 'dashboard') { %><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/><% } %>
          </svg>
        </div>
        <span class="msd-link-label"><%= item.label %></span>
      </a>
    <% }); %>
  </nav>

  <!-- Logout -->
  <div class="msd-bottom">
    <a class="msd-link msd-link-logout" href="/logout">
      <div class="msd-link-icon">
        <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
      </div>
      <span class="msd-link-label">تسجيل الخروج</span>
    </a>
  </div>
</div>

<!-- Bottom Navigation -->
<nav class="mobile-bottom-nav">
  <% var mainItems = navItems.filter(function(item) { return mobileMainIds.indexOf(item.id) !== -1; }); %>
  <% mainItems.forEach(function(item) { %>
    <% if (item.adminOnly && (!_navUser || _navUser.role !== 'admin')) return; %>
    <a class="mobile-nav-link <%= item.id === 'predictions' ? 'add-prediction' : '' %> <%= active === item.id ? 'active' : '' %>" href="<%= item.url %>">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <% if (item.icon === 'home') { %><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
        <% } else if (item.icon === 'schedule') { %><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
        <% } else if (item.icon === 'predict') { %><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        <% } else if (item.icon === 'list') { %><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
        <% } else if (item.icon === 'trophy') { %><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
        <% } %>
      </svg>
      <span><%= item.id === 'my-predictions' ? 'توقعاتي' : item.id === 'predictions' ? 'توقع' : item.label %></span>
    </a>
  <% }); %>

</nav>


<script>
// Drawer
(function() {
  var trigger = document.querySelector('[data-mobile-menu-trigger]');
  var drawer = document.querySelector('[data-mobile-drawer]');
  var overlay = document.querySelector('[data-mobile-drawer-overlay]');
  var closeBtn = document.querySelector('[data-mobile-drawer-close]');

  function openDrawer() {
    if (!drawer || !overlay) return;
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    document.body.classList.add('drawer-open');
  }

  function closeDrawer() {
    if (!drawer || !overlay) return;
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    document.body.classList.remove('drawer-open');
  }

  if (trigger) trigger.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeDrawer();
  });
})();
</script>