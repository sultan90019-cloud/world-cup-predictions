<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>أخبار كأس العالم - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'news', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

<%
  function timeAgo(date) {
    var diff = Math.floor((Date.now() - new Date(date)) / 1000);
    if (diff < 60) return 'الآن';
    if (diff < 3600) return 'قبل ' + Math.floor(diff/60) + ' دقيقة';
    if (diff < 86400) return 'قبل ' + Math.floor(diff/3600) + ' ساعة';
    return 'قبل ' + Math.floor(diff/86400) + ' يوم';
  }
  var displayNews = (newsItems || []).map(function(n) {
    return {
      id: n.id,
      title: n.title,
      excerpt: n.body,
      time: timeAgo(n.created_at),
      breaking: n.breaking,
      image: n.image_path || null
    };
  });
%>

        <!-- ===== MOBILE NEWS PAGE (≤860px) ===== -->
        <div class="nw">

          <!-- Header -->
          <div class="nw-header">
            <div class="nw-header-bg"></div>
            <div class="nw-header-inner">
              <div class="nw-logo">
                <img src="/logo.png" alt="شعار المسابقة" style="width:90px;height:90px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(212,175,55,0.35));">
              </div>
              <h1 class="nw-header-title">أخبار كأس العالم</h1>
              <p class="nw-header-sub">تابع آخر الأخبار وترتيب المجموعات لحظة بلحظة</p>
            </div>
          </div>

          <!-- Tabs -->
          <div class="nw-tabs">
            <button class="nw-tab-btn nw-tab-active" data-tab="standings" onclick="nwSwitchTab('standings')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
              </svg>
              <span>ترتيب المجموعات</span>
            </button>
            <button class="nw-tab-btn" data-tab="news" onclick="nwSwitchTab('news')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M22 3l-1.67 1.67L18.67 3 17 4.67 15.33 3l-1.66 1.67L12 3l-1.67 1.67L8.67 3 7 4.67 5.33 3 3.67 4.67 2 3v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V3zM11 19H4v-6h7v6zm9 0h-7v-2h7v2zm0-4h-7v-2h7v2zm0-4H4V8h16v3z"/>
              </svg>
              <span>أخبار كأس العالم</span>
            </button>
          </div>

          <!-- ===== TAB: NEWS ===== -->
          <div class="nw-panel" data-panel="news">

            <% if (displayNews.length === 0) { %>
              <!-- Empty State -->
              <div class="nw-empty">
                <div class="nw-empty-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                    <path d="M4 4h16v16H4z"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/>
                  </svg>
                </div>
                <h3 class="nw-empty-title">لا توجد أخبار حالياً</h3>
                <p class="nw-empty-text">سيتم نشر الأخبار من لوحة التحكم قريباً</p>
              </div>
            <% } else { %>
              <!-- Hero Card (first item) -->
              <%
                var hero = displayNews[0];
                var heroImgId = hero.id;
              %>
              <div class="nw-hero">
                <div class="nw-hero-img">
                  <% if (hero.image) { %>
                  <img src="<%= hero.image %>" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:inherit;" onerror="this.style.display='none'">
                  <% } else { %>
                  <svg class="nw-hero-placeholder" viewBox="0 0 400 225" preserveAspectRatio="xMidYMid slice">
                    <rect width="400" height="225" fill="rgba(255,255,255,0.04)"/>
                    <circle cx="200" cy="100" r="36" fill="rgba(212,175,55,0.12)"/>
                    <path d="M200 64 C216 64 229 77 229 93 C229 109 216 122 200 122 C184 122 171 109 171 93 C171 77 184 64 200 64Z" fill="rgba(212,175,55,0.2)"/>
                    <path d="M175 130 L200 150 L225 130 L215 160 L185 160 Z" fill="rgba(212,175,55,0.15)"/>
                    <line x1="140" y1="190" x2="260" y2="190" stroke="rgba(255,255,255,0.06)" stroke-width="2"/>
                    <circle cx="200" cy="190" r="4" fill="rgba(212,175,55,0.2)"/>
                  </svg>
                  <% } %>
                  <% if (hero.breaking) { %>
                    <span class="nw-breaking-badge">عاجل</span>
                  <% } %>
                </div>
                <div class="nw-hero-body">
                  <h2 class="nw-hero-title"><%= hero.title %></h2>
                  <p class="nw-hero-excerpt"><%= hero.excerpt %></p>
                  <div class="nw-hero-meta">
                    <span class="nw-hero-time">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <%= hero.time %>
                    </span>
                    <button class="nw-hero-btn nw-open-btn" data-idx="0">قراءة الخبر</button>
                  </div>
                </div>
              </div>

              <!-- Remaining News List -->
              <div class="nw-list">
                <% for (var i = 1; i < displayNews.length; i++) {
                  var item = displayNews[i];
                %>
                <div class="nw-card nw-open-btn" style="cursor:pointer;" data-idx="<%= i %>">
                  <div class="nw-card-img">
                    <% if (item.image) { %>
                    <img src="<%= item.image %>" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'">
                    <% } else { %>
                    <svg viewBox="0 0 110 74" preserveAspectRatio="xMidYMid slice">
                      <rect width="110" height="74" fill="rgba(255,255,255,0.04)"/>
                      <circle cx="55" cy="32" r="14" fill="rgba(212,175,55,0.12)"/>
                      <path d="M55 18 C63 18 69 24 69 32 C69 40 63 46 55 46 C47 46 41 40 41 32 C41 24 47 18 55 18Z" fill="rgba(212,175,55,0.18)"/>
                      <line x1="30" y1="58" x2="80" y2="58" stroke="rgba(255,255,255,0.06)" stroke-width="1.5"/>
                    </svg>
                    <% } %>
                  </div>
                  <div class="nw-card-body">
                    <h3 class="nw-card-title"><%= item.title %></h3>
                    <p class="nw-card-excerpt"><%= item.excerpt %></p>
                    <span class="nw-card-time">
                      <span class="nw-dot"></span>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <%= item.time %>
                    </span>
                  </div>
                </div>
                <% } %>
              </div>
            <% } %>

          </div>
          <!-- ===== END NEWS TAB ===== -->

          <!-- ===== TAB: GROUP STANDINGS ===== -->
          <div class="nw-panel nw-panel-active" data-panel="standings">

            <% if (!groups || groups.length === 0 || groups.every(function(g) { return !g.teams || g.teams.length === 0; })) { %>
              <!-- Empty State -->
              <div class="nw-empty">
                <div class="nw-empty-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                    <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
                  </svg>
                </div>
                <h3 class="nw-empty-title">لم تبدأ مباريات المجموعات بعد</h3>
                <p class="nw-empty-text">سيتم تحديث الترتيب تلقائياً بعد إدخال النتائج</p>
              </div>
            <% } else { %>
              <div class="nw-groups">
                <% groups.forEach(function(group) { %>
                <div class="nw-group-card">
                  <div class="nw-group-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                      <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/>
                    </svg>
                    <span><%= group.name %></span>
                  </div>

                  <% if (!group.teams || group.teams.length === 0) { %>
                    <div class="nw-group-empty">لا توجد فرق في هذه المجموعة</div>
                  <% } else { %>
                    <div class="nw-st-table">
                      <div class="nw-st-tr nw-st-head">
                        <span class="nw-st-td nw-st-rank">#</span>
                        <span class="nw-st-td nw-st-team-name">المنتخب</span>
                        <span class="nw-st-td">لعب</span>
                        <span class="nw-st-td">فاز</span>
                        <span class="nw-st-td nw-st-draws">ت</span>
                        <span class="nw-st-td">خسر</span>
                        <span class="nw-st-td nw-st-gf">له</span>
                        <span class="nw-st-td nw-st-ga">عليه</span>
                        <span class="nw-st-td nw-st-pts">نقاط</span>
                      </div>
                      <% group.teams.forEach(function(team, idx) { %>
                      <div class="nw-st-tr">
                        <span class="nw-st-td nw-st-rank">
                          <% if (idx === 0) { %><span class="nw-st-medal nw-st-gold">1</span>
                          <% } else if (idx === 1) { %><span class="nw-st-medal nw-st-silver">2</span>
                          <% } else if (idx === 2) { %><span class="nw-st-medal nw-st-bronze">3</span>
                          <% } else { %><span class="nw-st-num"><%= idx + 1 %></span><% } %>
                        </span>
                        <span class="nw-st-td nw-st-team-name">
                          <img class="nw-st-flag" src="/flags/<%= team.flag || team.name || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'">
                          <span class="nw-st-name"><%= team.name %></span>
                        </span>
                        <span class="nw-st-td"><%= team.played %></span>
                        <span class="nw-st-td"><%= team.wins %></span>
                        <span class="nw-st-td nw-st-draws"><%= team.draws %></span>
                        <span class="nw-st-td"><%= team.losses %></span>
                        <span class="nw-st-td nw-st-gf"><%= team.scored %></span>
                        <span class="nw-st-td nw-st-ga"><%= team.conceded %></span>
                        <span class="nw-st-td nw-st-pts"><%= team.points %></span>
                      </div>
                      <% }); %>
                    </div>
                  <% } %>
                </div>
                <% }); %>
              </div>

              <div class="nw-update-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                <span>يتم تحديث ترتيب المجموعات تلقائياً بعد اعتماد نتائج المباريات</span>
              </div>
            <% } %>

          </div>
          <!-- ===== END STANDINGS TAB ===== -->

        </div>
        <!-- ===== END MOBILE NEWS ===== -->

        <!-- ===== DESKTOP NEWS SECTION (≥861px) ===== -->
        <div class="nw-desktop">
          <div class="card section-card">
            <h2>آخر الأخبار</h2>
            <div class="news-list">
              <% newsItems.forEach(function(article) { %>
              <article>
                <h3><%= article.title %></h3>
                <p><%= article.excerpt %></p>
              </article>
              <% }); %>
              <% if (newsItems.length === 0) { %>
              <p>لا توجد أخبار حالياً</p>
              <% } %>
            </div>
          </div>

          <div class="card section-card">
            <div class="section-header">
              <div>
                <h2>ترتيب المجموعات</h2>
                <p>أحدث ترتيب للمجموعات بناءً على النتائج الفعلية.</p>
              </div>
            </div>
            <div class="group-grid">
              <% if (groups && groups.length > 0) {
                groups.forEach(function(group) { %>
                  <div class="group-card">
                    <div class="group-card-title">
                      <h3><%= group.name %></h3>
                      <span class="group-card-small">ترتيب المجموعة وإحصائياتها</span>
                    </div>
                    <% if (group.teams && group.teams.length > 0) { %>
                    <div class="group-table">
                      <div class="group-table-header">
                        <div class="group-cell team-column">المنتخب</div>
                        <div class="group-cell">لعب</div>
                        <div class="group-cell">فاز</div>
                        <div class="group-cell">تعادل</div>
                        <div class="group-cell">خسر</div>
                        <div class="group-cell">سجل</div>
                        <div class="group-cell">استقبل</div>
                        <div class="group-cell points-column">النقاط</div>
                      </div>
                      <% group.teams.forEach(function(team, index) { %>
                        <div class="group-row">
                          <div class="group-team team-column">
                            <span class="team-flag"><img src="/flags/<%= team.flag || team.name || 'unknown' %>.png" alt="علم <%= team.name %>" onerror="this.src='/flags/unknown.png'" /></span>
                            <span class="team-name"><%= team.name %></span>
                          </div>
                          <div class="group-cell"><%= team.played %></div>
                          <div class="group-cell"><%= team.wins %></div>
                          <div class="group-cell"><%= team.draws %></div>
                          <div class="group-cell"><%= team.losses %></div>
                          <div class="group-cell"><%= team.scored %></div>
                          <div class="group-cell"><%= team.conceded %></div>
                          <div class="group-cell points-column"><strong><%= team.points %></strong></div>
                        </div>
                      <% }); %>
                    </div>
                    <% } else { %>
                      <p>لا توجد فرق في هذه المجموعة</p>
                    <% } %>
                  </div>
              <% }); } else { %>
                <p>لا توجد مجموعات متاحة</p>
              <% } %>
            </div>
          </div>
        </div>

      </section>
    </main>
  </div>

  <!-- News Modal -->
  <div id="news-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);overflow-y:auto;padding:20px 0;" onclick="if(event.target===this)closeNews()">
    <div style="max-width:500px;margin:0 auto;background:var(--surface,#1a2540);border-radius:18px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
      <div id="nm-img-wrap" style="position:relative;width:100%;">
        <img id="nm-img" src="" style="width:100%;max-height:260px;object-fit:cover;display:none;">
        <span id="nm-breaking" style="display:none;position:absolute;top:12px;right:12px;background:#ef4444;color:#fff;font-size:0.75rem;font-weight:800;padding:3px 10px;border-radius:20px;">عاجل</span>
        <button onclick="closeNews()" style="position:absolute;top:12px;left:12px;background:rgba(0,0,0,0.5);border:none;border-radius:50%;width:34px;height:34px;color:#fff;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">&#x2715;</button>
      </div>
      <div style="padding:20px 18px 28px;">
        <h2 id="nm-title" style="font-size:1.05rem;font-weight:800;color:var(--text,#fff);margin:0 0 12px;line-height:1.5;"></h2>
        <p id="nm-body" style="font-size:0.88rem;color:var(--text-secondary,#9ab);line-height:1.8;margin:0 0 16px;white-space:pre-wrap;"></p>
        <div style="display:flex;align-items:center;gap:6px;color:var(--text-secondary,#9ab);font-size:0.78rem;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span id="nm-time"></span>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="news-json"><%- JSON.stringify(displayNews.map(function(n){ return { title: n.title, body: n.excerpt, img: n.image||'', brk: !!n.breaking, time: n.time }; })) %></script>
  <script>
    var NEWS_DATA = JSON.parse(document.getElementById('news-json').textContent);

    document.querySelectorAll('.nw-open-btn').forEach(function(el) {
      el.addEventListener('click', function() {
        var idx = parseInt(this.dataset.idx, 10);
        var n = NEWS_DATA[idx];
        if (!n) return;
        document.getElementById('nm-title').textContent = n.title;
        document.getElementById('nm-body').textContent  = n.body;
        document.getElementById('nm-time').textContent  = n.time;
        var imgEl = document.getElementById('nm-img');
        if (n.img) { imgEl.src = n.img; imgEl.style.display = 'block'; }
        else { imgEl.style.display = 'none'; }
        document.getElementById('nm-breaking').style.display = n.brk ? 'inline-block' : 'none';
        document.getElementById('news-modal').style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    });
    function closeNews() {
      document.getElementById('news-modal').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeNews(); });

    function nwSwitchTab(tab) {
      var btns = document.querySelectorAll('.nw-tab-btn');
      var panels = document.querySelectorAll('.nw-panel');
      btns.forEach(function(b) { b.classList.remove('nw-tab-active'); });
      panels.forEach(function(p) { p.classList.remove('nw-panel-active'); });
      var activeBtn = document.querySelector('.nw-tab-btn[data-tab="' + tab + '"]');
      var activePanel = document.querySelector('.nw-panel[data-panel="' + tab + '"]');
      if (activeBtn) activeBtn.classList.add('nw-tab-active');
      if (activePanel) activePanel.classList.add('nw-panel-active');
    }
  </script>
<%- include('partials/mobile-nav', { active: 'news' }) %>
</body>
</html>
