<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>توقعاتي - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'my-predictions', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

<%
  // Compute stats
  var mpCorrect = 0, mpClose = 0, mpWrong = 0, mpRemaining = 0, mpJudged = 0;
  predictions.forEach(function(p) {
    if (p.actual_scoreA == null) { mpRemaining++; return; }
    mpJudged++;
    if (p.points >= 20 || (p.round >= 4 && p.points >= 25)) mpCorrect++;
    else if (p.points >= 10) mpClose++;
    else mpWrong++;
  });
  var mpTotal = predictions.length;
  var mpSuccessRate = mpJudged > 0 ? Math.round(mpCorrect / mpJudged * 100) : 0;
  var mpRounds = [];
  predictions.forEach(function(p) { var r = p.round || 1; if (mpRounds.indexOf(r) === -1) mpRounds.push(r); });
  mpRounds.sort(function(a,b){ return a-b; });
  var mpMaxRound = mpRounds.length > 0 ? mpRounds[mpRounds.length - 1] : 1;
%>

        <!-- ===== MOBILE MY PREDICTIONS (≤860px) ===== -->
        <div class="mp">

          <!-- Header -->
          <div class="mp-header">
            <div class="mp-header-bg"></div>
            <div class="mp-header-inner">
              <div style="width:40px;"></div>
              <div class="mp-header-logo">
                <img src="/logo.png" alt="شعار المسابقة" style="width:56px;height:56px;object-fit:contain;filter:drop-shadow(0 2px 8px rgba(212,175,55,0.35));">
              </div>
              <span class="mp-header-guide" onclick="window.location='/rules'">دليل التوقع</span>
            </div>
            <h1 class="mp-header-title">توقعاتي</h1>
            <p class="mp-header-sub">جميع توقعاتك لبطولات كأس العالم 2026</p>
          </div>

          <!-- Stats Summary Card -->
          <div class="mp-stats">
            <div class="mp-stat">
              <div class="mp-stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
              </div>
              <span class="mp-stat-num"><%= userRank > 0 ? userRank : '-' %></span>
              <span class="mp-stat-lbl">ترتيبك العام</span>
            </div>
            <div class="mp-stat-vr"></div>
            <div class="mp-stat">
              <div class="mp-stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              <span class="mp-stat-num"><%= totalPoints %></span>
              <span class="mp-stat-lbl">إجمالي النقاط</span>
            </div>
            <div class="mp-stat-vr"></div>
            <div class="mp-stat">
              <div class="mp-stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <span class="mp-stat-num"><%= mpCorrect %></span>
              <span class="mp-stat-lbl">توقع صحيح</span>
            </div>
            <div class="mp-stat-vr"></div>
            <div class="mp-stat">
              <div class="mp-stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
              </div>
              <span class="mp-stat-num"><%= mpRemaining %></span>
              <span class="mp-stat-lbl">مباراة متبقية</span>
            </div>
          </div>

          <!-- Tabs -->
          <div class="mp-tabs" id="mpTabs" data-max-round="<%= mpMaxRound %>">
            <button class="mp-tab active" data-tab="current" onclick="mpSetTab('current')">الجولة الحالية</button>
            <button class="mp-tab" data-tab="upcoming" onclick="mpSetTab('upcoming')">الجولات القادمة</button>
            <button class="mp-tab" data-tab="all" onclick="mpSetTab('all')">جميع التوقعات</button>
          </div>

          <!-- Secondary Filters -->
          <div class="mp-sub-filters">
            <select class="mp-round-select" id="mpRoundSelect" onchange="mpFilterRound()">
              <option value="all">جميع الجولات</option>
              <% mpRounds.forEach(function(r) { %>
              <option value="<%= r %>">الجولة <%= r %></option>
              <% }); %>
            </select>
            <div class="mp-legend">
              <span class="mp-legend-item"><span class="mp-dot mp-dot-correct"></span>صحيح</span>
              <span class="mp-legend-item"><span class="mp-dot mp-dot-close"></span>قريب</span>
              <span class="mp-legend-item"><span class="mp-dot mp-dot-wrong"></span>خاطئ</span>
              <span class="mp-legend-item"><span class="mp-dot mp-dot-pending"></span>لم تبدأ</span>
            </div>
          </div>

          <!-- Prediction Cards -->
          <div class="mp-list" id="mpList">
            <% predictions.forEach(function(p) {
              var ended = p.actual_scoreA != null;
              var state = !ended ? 'pending' : p.points >= 20 ? 'correct' : p.points >= 10 ? 'close' : 'wrong';
              var stateLabel = state === 'correct' ? 'صحيح' : state === 'close' ? 'قريب' : state === 'wrong' ? 'خاطئ' : 'لم تبدأ';
              var pRound = p.round || 1;
              var now = new Date();
              var matchDate = new Date(p.start_at);
              var isFuture = matchDate > now;
            %>
            <div class="mp-card" data-state="<%= state %>" data-round="<%= pRound %>" data-future="<%= isFuture %>">
              <!-- State Badge -->
              <div class="mp-card-state mp-state-<%= state %>">
                <span class="mp-state-label">
                  <% if (state === 'correct') { %>
                    <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  <% } else if (state === 'close') { %>
                    <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  <% } else if (state === 'wrong') { %>
                    <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                  <% } else { %>
                    <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/></svg>
                  <% } %>
                  <%= stateLabel %>
                </span>
                <% if (ended) { %><span class="mp-card-points">+<%= p.points %></span><% } %>
              </div>

              <!-- Body -->
              <div class="mp-card-body">
                <div class="mp-team">
                  <img src="/flags/<%= teamFlags[p.teamA] || 'unknown' %>.png" alt="" class="mp-flag" onerror="this.src='/flags/unknown.png'">
                  <span class="mp-team-name"><%= p.teamA %></span>
                  <div class="mp-score-box">
                    <span class="mp-sbox-lbl">توقعك</span>
                    <span class="mp-sbox-num"><%= p.scoreA %></span>
                  </div>
                  <% if (ended) { %>
                  <div class="mp-score-box mp-score-actual">
                    <span class="mp-sbox-lbl">النتيجة</span>
                    <span class="mp-sbox-num"><%= p.actual_scoreA %></span>
                  </div>
                  <% } %>
                </div>

                <div class="mp-score-col">
                  <span class="mp-date"><%= matchDate.toLocaleDateString('ar-SA', { weekday:'long', month:'long', day:'numeric', timeZone:'Asia/Riyadh' }) %></span>
                  <span class="mp-time"><%= matchDate.toLocaleTimeString('ar-EG', { hour:'2-digit', minute:'2-digit', timeZone:'Asia/Riyadh' }) %></span>
                </div>

                <div class="mp-team">
                  <img src="/flags/<%= teamFlags[p.teamB] || 'unknown' %>.png" alt="" class="mp-flag" onerror="this.src='/flags/unknown.png'">
                  <span class="mp-team-name"><%= p.teamB %></span>
                  <div class="mp-score-box">
                    <span class="mp-sbox-lbl">توقعك</span>
                    <span class="mp-sbox-num"><%= p.scoreB %></span>
                  </div>
                  <% if (ended) { %>
                  <div class="mp-score-box mp-score-actual">
                    <span class="mp-sbox-lbl">النتيجة</span>
                    <span class="mp-sbox-num"><%= p.actual_scoreB %></span>
                  </div>
                  <% } %>
                </div>
              </div>

              <!-- Expand -->
              <button class="mp-expand-btn" onclick="this.parentElement.classList.toggle('mp-expanded')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>

              <!-- Expand Details -->
              <div class="mp-details">
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">المجموعة</span>
                  <span class="mp-dtl-val"><%= p.stage || '-' %></span>
                </div>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">الجولة</span>
                  <span class="mp-dtl-val"><%= pRound %></span>
                </div>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">تاريخ التوقع</span>
                  <span class="mp-dtl-val"><%= new Date(p.updated_at || p.start_at).toLocaleString('ar-EG', { timeZone: 'Asia/Riyadh' }) %></span>
                </div>
                <% if (ended) { %>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">النقاط المكتسبة</span>
                  <span class="mp-dtl-val mp-dtl-green">+<%= p.points %></span>
                </div>
                <% if (p.penalty_winner) { %>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">ركلات الترجيح</span>
                  <span class="mp-dtl-val"><%= p.penalty_winner %></span>
                </div>
                <% } %>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">التقييم</span>
                  <span class="mp-dtl-val"><%= stateLabel %></span>
                </div>
                <% } else { %>
                <div class="mp-dtl-row">
                  <span class="mp-dtl-lbl">الحالة</span>
                  <span class="mp-dtl-val mp-dtl-muted">المباراة لم تبدأ بعد</span>
                </div>
                <% } %>
              </div>
            </div>
            <% }); %>
          </div>

          <!-- Empty State -->
          <% if (predictions.length === 0) { %>
          <div class="mp-empty">
            <div class="mp-empty-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="48" height="48"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
            </div>
            <h3 class="mp-empty-title">لا توجد توقعات حتى الآن</h3>
            <p class="mp-empty-text">ابدأ بإضافة توقعاتك للمباريات القادمة</p>
            <a href="/predictions" class="mp-empty-btn">إضافة توقع</a>
          </div>
          <% } %>

          <!-- Performance Summary -->
          <% if (mpTotal > 0) { %>
          <div class="mp-summary">
            <div class="mp-summary-head">
              <span>ملخص أدائك</span>
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
            </div>
            <div class="mp-summary-body">
              <div class="mp-summary-row">
                <span class="mp-sr-lbl">نسبة النجاح</span>
                <span class="mp-sr-val mp-sr-val-gold"><%= mpSuccessRate %>%</span>
              </div>
              <div class="mp-summary-row">
                <span class="mp-sr-lbl">توقع صحيح</span>
                <span class="mp-sr-val mp-sr-val-green"><%= mpCorrect %></span>
              </div>
              <div class="mp-summary-row">
                <span class="mp-sr-lbl">قريب من الصحيح</span>
                <span class="mp-sr-val mp-sr-val-yellow"><%= mpClose %></span>
              </div>
              <div class="mp-summary-row">
                <span class="mp-sr-lbl">خاطئ</span>
                <span class="mp-sr-val mp-sr-val-red"><%= mpWrong %></span>
              </div>
              <div class="mp-summary-row mp-summary-total">
                <span class="mp-sr-lbl">إجمالي النقاط</span>
                <span class="mp-sr-val"><%= totalPoints %></span>
              </div>
            </div>
          </div>
          <% } %>

        </div>
        <!-- ===== END MOBILE MY PREDICTIONS ===== -->

        <!-- ===== DESKTOP MY PREDICTIONS (≥861px) ===== -->
        <div class="mp-desktop">
          <div class="card section-card">
            <h2>توقعاتك المسجّلة</h2>
            <p>اطّلع على جميع توقعاتك ونقاطك لكل مباراة.</p>
            <div class="prediction-list">
              <% predictions.forEach(function(p) { %>
                <div class="prediction-card">
                  <div class="prediction-top">
                    <div class="match-title">
                      <span class="team-inline"><span class="team-flag"><img src="/flags/<%= teamFlags[p.teamA] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'" /></span><span class="team-name"><strong><%= p.teamA %></strong></span></span>
                      X
                      <span class="team-inline"><span class="team-flag"><img src="/flags/<%= teamFlags[p.teamB] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'" /></span><span class="team-name"><strong><%= p.teamB %></strong></span></span>
                    </div>
                    <span class="badge <%= p.actual_scoreA == null ? 'locked' : 'open' %>"><%= p.actual_scoreA == null ? 'قيد الانتظار' : 'انتهت' %></span>
                  </div>
                  <div class="prediction-body">
                    <div class="prediction-detail">
                      <div class="detail-label">توقعت</div>
                      <div class="detail-value"><%= p.teamA %> <%= p.scoreA %> - <%= p.teamB %> <%= p.scoreB %><% if (p.round >= 4 && p.predicted_winner) { %> · المتأهل: <%= p.predicted_winner %><% } %></div>
                    </div>
                    <div class="prediction-detail">
                      <div class="detail-label">النتيجة</div>
                      <div class="detail-value"><% if (p.actual_scoreA == null) { %>لم تُسجَّل<% } else { %><%= p.teamA %> <%= p.actual_scoreA %> - <%= p.teamB %> <%= p.actual_scoreB %><% } %></div>
                    </div>
                    <div class="prediction-detail">
                      <div class="detail-label">النقاط</div>
                      <div class="detail-value"><%= p.points %></div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>

      </section>
    </main>
  </div>

  <script>
    var mpMaxRound = parseInt(document.getElementById('mpTabs').getAttribute('data-max-round')) || 999;
    function mpSetTab(tab) {
      document.querySelectorAll('.mp-tab').forEach(function(t) { t.classList.remove('active'); });
      document.querySelector('.mp-tab[data-tab="' + tab + '"]').classList.add('active');
      var now = new Date();
      document.querySelectorAll('.mp-card').forEach(function(c) {
        var round = parseInt(c.getAttribute('data-round')) || 1;
        var isFuture = c.getAttribute('data-future') === 'true';
        if (tab === 'current') {
          c.style.display = round === mpMaxRound ? '' : 'none';
        } else if (tab === 'upcoming') {
          c.style.display = isFuture ? '' : 'none';
        } else {
          c.style.display = '';
        }
      });
    }
    function mpFilterRound() {
      var val = document.getElementById('mpRoundSelect').value;
      document.querySelectorAll('.mp-card').forEach(function(c) {
        var round = c.getAttribute('data-round');
        c.style.display = (val === 'all' || round === val) ? '' : 'none';
      });
    }
  </script>
<%- include('partials/mobile-nav', { active: 'my-predictions' }) %>
</body>
</html>
