<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>ترتيب المتسابقين - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'leaderboard', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content" style="gap:0;padding:0;">

<style>
:root {
  --lb-pri: #2563EB;
  --lb-sky: #60A5FA;
  --lb-purp: #7C3AED;
  --lb-pink: #EC4899;
  --lb-gold: #FACC15;
  --lb-org: #F97316;
  --lb-grn: #22C55E;
  --lb-red: #EF4444;
  --lb-dark: #0F172A;
  --lb-muted: #64748B;
  --lb-card: #FFFFFF;
  --lb-border: #DCEBFF;
}
.lb-wrap {
  padding: 0 12px 90px;
  max-width: 1100px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.lb-section {
  background:
    linear-gradient(180deg, #EAF6FF 0%, #FFFFFF 45%, #F7FAFF 100%);
  position: relative;
  overflow: hidden;
}
/* stadium overlay */
.lb-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 280px;
  background:
    radial-gradient(ellipse 120% 100px at 50% 0%, rgba(37,99,235,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 80% 80px at 30% 20%, rgba(96,165,250,0.05) 0%, transparent 70%),
    radial-gradient(ellipse 90% 90px at 70% 10%, rgba(124,58,237,0.04) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}
/* confetti pieces */
.lb-confetti {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 200px;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
}
.lb-confetti span {
  position: absolute;
  width: 8px; height: 8px;
  border-radius: 2px;
  opacity: 0.4;
  animation: lbConfettiFall 4s ease-in-out infinite;
}
.lb-confetti span:nth-child(1) { left: 10%; top: -8px; background: var(--lb-pri); animation-delay: 0s; width: 6px; height: 6px; border-radius: 50%; }
.lb-confetti span:nth-child(2) { left: 25%; top: -8px; background: var(--lb-purp); animation-delay: 0.8s; width: 10px; height: 6px; }
.lb-confetti span:nth-child(3) { left: 40%; top: -8px; background: var(--lb-gold); animation-delay: 1.6s; width: 7px; height: 7px; border-radius: 50%; }
.lb-confetti span:nth-child(4) { left: 55%; top: -8px; background: var(--lb-pink); animation-delay: 0.4s; width: 5px; height: 8px; }
.lb-confetti span:nth-child(5) { left: 70%; top: -8px; background: var(--lb-grn); animation-delay: 2s; width: 9px; height: 5px; }
.lb-confetti span:nth-child(6) { left: 85%; top: -8px; background: var(--lb-sky); animation-delay: 1.2s; width: 6px; height: 6px; border-radius: 50%; }
.lb-confetti span:nth-child(7) { left: 50%; top: -8px; background: var(--lb-org); animation-delay: 2.4s; width: 8px; height: 4px; }
.lb-confetti span:nth-child(8) { left: 15%; top: -8px; background: var(--lb-pri); animation-delay: 0.6s; width: 5px; height: 9px; }
.lb-confetti span:nth-child(9) { left: 65%; top: -8px; background: var(--lb-purp); animation-delay: 1.8s; width: 7px; height: 7px; border-radius: 50%; }
.lb-confetti span:nth-child(10) { left: 35%; top: -8px; background: var(--lb-pink); animation-delay: 2.8s; width: 6px; height: 5px; }
@keyframes lbConfettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 0.4; }
  50% { opacity: 0.6; }
  100% { transform: translateY(200px) rotate(360deg); opacity: 0; }
}

/* ===== HEADER ===== */
.lb-header {
  position: relative;
  z-index: 2;
  padding-top: 10px;
  text-align: center;
}
.lb-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4px;
  margin-bottom: 12px;
}
.lb-guide-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.85);
  border: 1px solid #2F80ED;
  color: #2563EB;
  padding: 8px 16px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  box-shadow: 0 8px 20px rgba(37,99,235,0.12);
  transition: transform 0.2s, box-shadow 0.2s;
}
.lb-guide-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 24px rgba(37,99,235,0.18); }
.lb-guide-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.lb-header-logo {
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb-header-logo img {
  width: 52px;
  height: 52px;
  object-fit: contain;
}
.lb-menu-btn {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  border: none;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 10px 25px rgba(37,99,235,0.25);
  transition: transform 0.2s;
}
.lb-menu-btn:hover { transform: scale(1.05); }
.lb-menu-btn svg { width: 22px; height: 22px; }

.lb-title {
  font-size: 34px;
  font-weight: 900;
  margin: 0 0 6px;
  background: linear-gradient(90deg, #1D4ED8, #7C3AED);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.lb-update-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--lb-muted);
  background: rgba(255,255,255,0.7);
  padding: 5px 14px;
  border-radius: 999px;
  border: 1px solid #E5EEF9;
}
.lb-update-badge svg { width: 14px; height: 14px; color: var(--lb-grn); flex-shrink: 0; }

/* ===== PODIUM ===== */
.lb-podium-wrap {
  position: relative;
  z-index: 2;
  margin: 20px 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8px;
}
.lb-pod-card {
  flex: 1;
  max-width: 34%;
  border-radius: 20px;
  padding: 18px 8px 16px;
  text-align: center;
  position: relative;
  transition: transform 0.3s;
}
.lb-pod-card:hover { transform: translateY(-3px); }
.lb-pod-gold {
  background: linear-gradient(180deg, #FFF7D6 0%, #FFFFFF 100%);
  border: 2px solid #FACC15;
  box-shadow: 0 20px 45px rgba(250,204,21,0.35), 0 0 0 6px rgba(250,204,21,0.08);
  order: 2;
  max-width: 38%;
  padding: 24px 8px 20px;
}
.lb-pod-silver {
  background: linear-gradient(180deg, #EFF6FF 0%, #FFFFFF 100%);
  border: 2px solid #60A5FA;
  box-shadow: 0 16px 35px rgba(96,165,250,0.25);
  order: 1;
}
.lb-pod-bronze {
  background: linear-gradient(180deg, #FAF5FF 0%, #FFFFFF 100%);
  border: 2px solid #C084FC;
  box-shadow: 0 16px 35px rgba(192,132,252,0.25);
  order: 3;
}
.lb-pod-empty {
  opacity: 0.4;
  border-style: dashed;
}
.lb-pod-medal {
  font-size: 1.8rem;
  margin-bottom: 2px;
}
.lb-pod-gold .lb-pod-medal { font-size: 2.2rem; }
.lb-pod-rank {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.78rem;
  font-weight: 800;
  color: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
}
.lb-pod-gold .lb-pod-rank { background: linear-gradient(135deg, #FACC15, #EAB308); width: 32px; height: 32px; font-size: 0.85rem; }
.lb-pod-silver .lb-pod-rank { background: linear-gradient(135deg, #94A3B8, #64748B); }
.lb-pod-bronze .lb-pod-rank { background: linear-gradient(135deg, #CD7F32, #A0622E); }
.lb-pod-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  margin: 0 auto 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb-pod-gold .lb-pod-avatar {
  width: 68px;
  height: 68px;
  background: linear-gradient(135deg, rgba(250,204,21,0.15), rgba(250,204,21,0.05));
  border: 3px solid rgba(250,204,21,0.3);
  color: var(--lb-gold);
}
.lb-pod-silver .lb-pod-avatar {
  background: linear-gradient(135deg, rgba(96,165,250,0.12), rgba(96,165,250,0.04));
  border: 3px solid rgba(96,165,250,0.25);
  color: var(--lb-sky);
}
.lb-pod-bronze .lb-pod-avatar {
  background: linear-gradient(135deg, rgba(192,132,252,0.12), rgba(192,132,252,0.04));
  border: 3px solid rgba(192,132,252,0.25);
  color: #C084FC;
}
.lb-pod-avatar svg { width: 28px; height: 28px; }
.lb-pod-gold .lb-pod-avatar svg { width: 34px; height: 34px; }
.lb-pod-crown-label {
  font-size: 0.68rem;
  font-weight: 700;
  color: var(--lb-gold);
  background: rgba(250,204,21,0.1);
  padding: 2px 10px;
  border-radius: 20px;
  display: inline-block;
  margin-bottom: 4px;
}
.lb-pod-name {
  font-size: 0.85rem;
  font-weight: 800;
  color: var(--lb-dark);
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.lb-pod-gold .lb-pod-name { font-size: 1rem; }
.lb-pod-pts {
  font-size: 1rem;
  font-weight: 900;
  color: var(--lb-dark);
  margin-bottom: 3px;
}
.lb-pod-gold .lb-pod-pts { font-size: 1.2rem; color: #CA8A04; }
.lb-pod-silver .lb-pod-pts { color: var(--lb-pri); }
.lb-pod-bronze .lb-pod-pts { color: var(--lb-purp); }
.lb-pod-correct {
  font-size: 0.7rem;
  color: var(--lb-muted);
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(255,255,255,0.6);
  padding: 2px 10px;
  border-radius: 999px;
}
.lb-pod-correct strong { color: var(--lb-dark); font-weight: 700; }

/* ===== MY RANK CARD ===== */
.lb-myrank {
  position: relative;
  z-index: 2;
  margin: 16px 0;
  background: linear-gradient(135deg, rgba(37,99,235,0.06), rgba(124,58,237,0.06));
  border: 1px solid #DCEBFF;
  border-radius: 18px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.lb-myrank-avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--lb-pri), var(--lb-purp));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.lb-myrank-avatar svg { width: 22px; height: 22px; }
.lb-myrank-info { flex: 1; min-width: 0; }
.lb-myrank-label { font-size: 0.72rem; color: var(--lb-muted); margin-bottom: 2px; }
.lb-myrank-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
.lb-myrank-num {
  font-size: 1.1rem;
  font-weight: 900;
  color: var(--lb-pri);
}
.lb-myrank-pts {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--lb-dark);
}
.lb-myrank-gap {
  font-size: 0.72rem;
  color: var(--lb-muted);
}
.lb-myrank-gap strong { color: var(--lb-dark); }
.lb-myrank-bar-wrap {
  margin-top: 6px;
  height: 4px;
  background: rgba(37,99,235,0.1);
  border-radius: 4px;
  overflow: hidden;
}
.lb-myrank-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--lb-pri), var(--lb-purp));
  border-radius: 4px;
  transition: width 0.5s;
}

/* ===== TABLE CARD ===== */
.lb-table-card {
  position: relative;
  z-index: 2;
  background: rgba(255,255,255,0.92);
  border: 1px solid #DCEBFF;
  border-radius: 24px;
  box-shadow: 0 15px 40px rgba(15,23,42,0.08);
  overflow: hidden;
  margin-bottom: 20px;
}
.lb-table-tabs {
  display: flex;
  border-bottom: 1px solid #E5EEF9;
  background: #FAFCFF;
}
.lb-tab {
  flex: 1;
  padding: 12px 0;
  text-align: center;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--lb-muted);
  cursor: pointer;
  border: none;
  background: transparent;
  transition: all 0.2s;
  position: relative;
}
.lb-tab.active {
  color: #2563EB;
  background: #EFF6FF;
}
.lb-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 3px;
  background: #3B82F6;
  border-radius: 3px 3px 0 0;
}
.lb-table-header {
  display: flex;
  align-items: center;
  padding: 10px 14px;
  background: #FAFCFF;
  border-bottom: 1px solid #E5EEF9;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--lb-muted);
}
.lb-th-rank { width: 44px; text-align: center; flex-shrink: 0; }
.lb-th-player { flex: 1; min-width: 0; padding-right: 8px; }
.lb-th-pts { width: 60px; text-align: center; flex-shrink: 0; }
.lb-th-correct { width: 48px; text-align: center; flex-shrink: 0; }
.lb-th-move { width: 40px; text-align: center; flex-shrink: 0; }
.lb-table-body {}
.lb-row {
  display: flex;
  align-items: center;
  padding: 12px 14px;
  border-bottom: 1px solid #E5EEF9;
  transition: background 0.15s;
}
.lb-row:last-child { border-bottom: none; }
.lb-row:hover { background: #F8FAFF; }
.lb-row-me { background: #EFF6FF !important; }
.lb-row-rank {
  width: 44px;
  text-align: center;
  flex-shrink: 0;
  font-size: 0.85rem;
  font-weight: 800;
  color: var(--lb-muted);
}
.lb-rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  font-size: 0.78rem;
  font-weight: 800;
  color: #fff;
}
.lb-rank-gold { background: linear-gradient(135deg, #FACC15, #EAB308); }
.lb-rank-silver { background: linear-gradient(135deg, #94A3B8, #64748B); }
.lb-rank-bronze { background: linear-gradient(135deg, #CD7F32, #A0622E); }
.lb-row-player {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-right: 8px;
}
.lb-row-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
}
.lb-row-avatar svg { width: 16px; height: 16px; }
.lb-avatar-c1 { background: linear-gradient(135deg, #165dff, #1170ff); }
.lb-avatar-c2 { background: linear-gradient(135deg, #10b981, #059669); }
.lb-avatar-c3 { background: linear-gradient(135deg, #F4C542, #d4a830); }
.lb-avatar-c4 { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
.lb-avatar-c5 { background: linear-gradient(135deg, #f59e0b, #d97706); }
.lb-avatar-c6 { background: linear-gradient(135deg, #ef4444, #dc2626); }
.lb-row-name {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--lb-dark);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.lb-row-me-tag {
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--lb-pri);
  background: rgba(37,99,235,0.1);
  padding: 1px 8px;
  border-radius: 999px;
  flex-shrink: 0;
}
.lb-row-pts {
  width: 60px;
  text-align: center;
  flex-shrink: 0;
  font-size: 0.85rem;
  font-weight: 900;
  color: var(--lb-dark);
}
.lb-row-pts-1 { color: #CA8A04; }
.lb-row-pts-2 { color: var(--lb-pri); }
.lb-row-pts-3 { color: var(--lb-purp); }
.lb-row-correct {
  width: 48px;
  text-align: center;
  flex-shrink: 0;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--lb-muted);
}
.lb-row-move {
  width: 40px;
  text-align: center;
  flex-shrink: 0;
  font-size: 0.75rem;
  font-weight: 700;
}
.lb-move-up { color: var(--lb-grn); }
.lb-move-down { color: var(--lb-red); }
.lb-move-none { color: #CBD5E1; }
.lb-empty-msg {
  padding: 40px 20px;
  text-align: center;
  color: var(--lb-muted);
  font-size: 0.85rem;
}

/* ===== STATS CARDS ===== */
.lb-stats-row {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 8px;
}
.lb-stat-card {
  border-radius: 18px;
  padding: 18px 16px;
  position: relative;
  overflow: hidden;
}
.lb-stat-part {
  background: linear-gradient(135deg, #D1FAE5, #ECFDF5);
  color: #059669;
}
.lb-stat-pred {
  background: linear-gradient(135deg, #DBEAFE, #EFF6FF);
  color: #2563EB;
}
.lb-stat-cta {
  grid-column: 1 / -1;
  background: linear-gradient(135deg, #F5D0FE, #EDE9FE);
  color: #7C3AED;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 60px;
  min-height: 80px;
}
.lb-stat-icon {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
  background: rgba(255,255,255,0.5);
}
.lb-stat-icon svg { width: 20px; height: 20px; }
.lb-stat-num {
  font-size: 1.4rem;
  font-weight: 900;
  line-height: 1.1;
}
.lb-stat-label {
  font-size: 0.72rem;
  font-weight: 600;
  margin-top: 2px;
  opacity: 0.7;
}
.lb-stat-cta-text {
  font-size: 0.85rem;
  font-weight: 800;
  line-height: 1.3;
}
.lb-stat-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #7C3AED;
  color: #fff;
  padding: 10px 20px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 6px 16px rgba(124,58,237,0.25);
  transition: transform 0.2s;
  white-space: nowrap;
}
.lb-stat-cta-btn:hover { transform: translateY(-2px); }
.lb-stat-cta-deco {
  position: absolute;
  bottom: 6px;
  left: 10px;
  font-size: 3rem;
  opacity: 0.2;
  pointer-events: none;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 860px) {
  .lb-header-top { padding: 0 4px; }
}
@media (min-width: 861px) {
  .lb-wrap { padding: 20px 20px 30px; }
  .lb-title { font-size: 34px; }
  .lb-menu-btn { display: none; }
  .lb-stats-row { grid-template-columns: 1fr 1fr 1.5fr; }
  .lb-stat-cta { grid-column: auto; }
}
</style>

<div class="lb-section">
<div class="lb-confetti">
  <span></span><span></span><span></span><span></span><span></span>
  <span></span><span></span><span></span><span></span><span></span>
</div>

<div class="lb-wrap">

  <!-- ===== HEADER ===== -->
  <div class="lb-header">
    <div class="lb-header-top">
      <a href="/rules" class="lb-guide-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        دليل التوقع
      </a>
      <div class="lb-header-logo">
        <img src="/logo.png" alt="شعار المسابقة">
      </div>
      <button class="lb-menu-btn" data-mobile-menu-trigger aria-label="فتح القائمة">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      </button>
    </div>
    <h1 class="lb-title">ترتيب المتسابقين</h1>
    <div class="lb-update-badge">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      آخر تحديث قبل 3 دقائق
    </div>
  </div>

  <!-- ===== PODIUM ===== -->
  <div class="lb-podium-wrap">
    <% if (leaderboard.length >= 2) { %>
    <div class="lb-pod-card lb-pod-silver">
      <div class="lb-pod-rank">2</div>
      <div class="lb-pod-medal">🥈</div>
      <div class="lb-pod-avatar">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      </div>
      <div class="lb-pod-name"><%= leaderboard[1].name %></div>
      <div class="lb-pod-pts"><%= leaderboard[1].total.toLocaleString('ar-EG') %> نقطة</div>
      <div class="lb-pod-correct"><strong><%= leaderboard[1].correct_predictions %></strong> توقع صحيح</div>
    </div>
    <% } else { %>
    <div class="lb-pod-card lb-pod-silver lb-pod-empty"><div class="lb-pod-name" style="margin-top:20px;">—</div></div>
    <% } %>

    <% if (leaderboard.length >= 1) { %>
    <div class="lb-pod-card lb-pod-gold">
      <div class="lb-pod-rank">1</div>
      <div class="lb-pod-medal">👑</div>
      <div class="lb-pod-crown-label">بطل التوقعات</div>
      <div class="lb-pod-avatar">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      </div>
      <div class="lb-pod-name"><%= leaderboard[0].name %></div>
      <div class="lb-pod-pts"><%= leaderboard[0].total.toLocaleString('ar-EG') %> نقطة</div>
      <div class="lb-pod-correct"><strong><%= leaderboard[0].correct_predictions %></strong> توقع صحيح</div>
    </div>
    <% } else { %>
    <div class="lb-pod-card lb-pod-gold lb-pod-empty"><div class="lb-pod-name" style="margin-top:24px;">—</div></div>
    <% } %>

    <% if (leaderboard.length >= 3) { %>
    <div class="lb-pod-card lb-pod-bronze">
      <div class="lb-pod-rank">3</div>
      <div class="lb-pod-medal">🥉</div>
      <div class="lb-pod-avatar">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      </div>
      <div class="lb-pod-name"><%= leaderboard[2].name %></div>
      <div class="lb-pod-pts"><%= leaderboard[2].total.toLocaleString('ar-EG') %> نقطة</div>
      <div class="lb-pod-correct"><strong><%= leaderboard[2].correct_predictions %></strong> توقع صحيح</div>
    </div>
    <% } else { %>
    <div class="lb-pod-card lb-pod-bronze lb-pod-empty"><div class="lb-pod-name" style="margin-top:20px;">—</div></div>
    <% } %>
  </div>

  <!-- ===== MY RANK ===== -->
  <% if (userEntry) { %>
  <div class="lb-myrank">
    <div class="lb-myrank-avatar">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
    </div>
    <div class="lb-myrank-info">
      <div class="lb-myrank-label">ترتيبك الحالي</div>
      <div class="lb-myrank-row">
        <span class="lb-myrank-num">#<%= userRank %></span>
        <span class="lb-myrank-pts"><%= userEntry.total.toLocaleString('ar-EG') %> نقطة</span>
        <span class="lb-myrank-gap">
          <% if (gapToFifth > 0) { %>
            تبعد <strong><%= gapToFifth.toLocaleString('ar-EG') %></strong> نقطة عن الخامس
          <% } else if (userRank <= 5) { %>
            <strong>ضمن أفضل 5</strong>
          <% } else { %>
            لا يوجد متسابقون كافيون
          <% } %>
        </span>
      </div>
      <div class="lb-myrank-bar-wrap">
        <div class="lb-myrank-bar" style="width: <%= Math.min(100, leaderboard[0] ? (userEntry.total / leaderboard[0].total) * 100 : 0) %>%"></div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ===== TABLE ===== -->
  <div class="lb-table-card">
    <div class="lb-table-tabs">
      <button class="lb-tab active">الترتيب 🏆</button>
      <button class="lb-tab" onclick="lbSetSort('success_rate', this)">التوقعات الصحيحة ✅</button>
    </div>
    <div class="lb-table-header">
      <span class="lb-th-rank">#</span>
      <span class="lb-th-player">المتسابق</span>
      <span class="lb-th-pts">النقاط</span>
      <span class="lb-th-correct">صحيح</span>
      <span class="lb-th-move">حركة</span>
    </div>
    <div class="lb-table-body" id="lbTableBody">
      <% if (leaderboard.length <= 3) { %>
      <div class="lb-empty-msg">
        <div style="font-size:2.5rem;margin-bottom:8px;">🏆</div>
        <p>لم يكتمل الترتيب بعد<br>سيظهر بعد تسجيل أول النتائج</p>
      </div>
      <% } else { %>
      <% leaderboard.slice(3).forEach(function(p, i) { var rank = i + 4; var isMe = p.id === user.id; %>
      <div class="lb-row <%= isMe ? 'lb-row-me' : '' %>">
        <span class="lb-row-rank"><%= rank %></span>
        <div class="lb-row-player">
          <div class="lb-row-avatar lb-avatar-c<%= (rank % 6) + 1 %>">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          </div>
          <span class="lb-row-name"><%= p.name %></span>
          <% if (isMe) { %><span class="lb-row-me-tag">أنت</span><% } %>
        </div>
        <span class="lb-row-pts"><%= p.total.toLocaleString('ar-EG') %></span>
        <span class="lb-row-correct"><%= p.correct_predictions %></span>
        <span class="lb-row-move lb-move-none">—</span>
      </div>
      <% }); } %>
    </div>
  </div>

  <!-- ===== STATS CARDS ===== -->
  <div class="lb-stats-row">
    <div class="lb-stat-card lb-stat-part">
      <div class="lb-stat-icon">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
      </div>
      <div class="lb-stat-num"><%= (stats?.totalPlayers || leaderboard.length).toLocaleString('ar-EG') %></div>
      <div class="lb-stat-label">مشارك</div>
    </div>
    <div class="lb-stat-card lb-stat-pred">
      <div class="lb-stat-icon">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
      </div>
      <div class="lb-stat-num"><%= (stats?.totalPredictions || 0).toLocaleString('ar-EG') %></div>
      <div class="lb-stat-label">توقع</div>
    </div>
    <div class="lb-stat-card lb-stat-cta">
      <div>
        <div class="lb-stat-cta-text">نافس أصدقاءك<br>وكن بطل التوقعات</div>
        <a href="/predictions" class="lb-stat-cta-btn" style="margin-top:8px;">
          ابدأ التوقع الآن
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="lb-stat-cta-deco">🏆</div>
    </div>
  </div>

</div><!-- /lb-wrap -->
</div><!-- /lb-section -->

      </section>
    </main>
  </div>

  <script>
    function lbSetSort(type, btn) {
      document.querySelectorAll('.lb-tab').forEach(function(t) { t.classList.remove('active'); });
      if (btn) btn.classList.add('active');
    }
  </script>
<%- include('partials/mobile-nav', { active: 'leaderboard' }) %>
</body>
</html>
