<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>توقعات المتسابقين - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .pp-mini-flag { width:18px; height:18px; border-radius:3px; object-fit:cover; vertical-align:middle; }
    .pp-score-dash { margin:0 2px; color:#94a3b8; }
    .pp-single { margin-top:4px; font-size:13px !important; padding:3px 10px !important; }
    .pp-vs-dash { font-size:16px; font-weight:900; color:#94a3b8; }
    .pp-single-desktop { font-size:0.9rem; padding:2px 10px; border-radius:8px; background:linear-gradient(135deg,#D4AF37,#B8960F); color:#fff; font-weight:900; line-height:1.4; }
    .pp-dash-desktop { font-size:1.1rem; font-weight:900; color:#94a3b8; }
    .pp-no-pred-text { color:#ef4444; font-size:0.78rem; font-weight:700; }
    .pp-pred-no-score { color:#ef4444; font-size:0.85rem; font-weight:700; white-space:nowrap; }
  </style>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'players-predictions', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

<%
  // Build accuracy lookup from leaderboard
  var ppAccMap = {};
  if (typeof leaderboard !== 'undefined') {
    leaderboard.forEach(function(entry) {
      ppAccMap[entry.id] = entry.success_rate || 0;
    });
  }
%>

<%
  var ppTodayKey = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
  var ppYesterdayD = new Date(); ppYesterdayD.setDate(ppYesterdayD.getDate() - 1);
  var ppYesterdayKey = ppYesterdayD.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
  function ppDateKey(d) {
    if (!d) return '';
    try { return new Date(d).toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' }); } catch(e) { return ''; }
  }
  var ppCountAll = matchesWithPredictions.length;
  var ppCountToday = 0, ppCountYesterday = 0;
  matchesWithPredictions.forEach(function(item) {
    var dk = ppDateKey(item.match.start_at);
    if (dk === ppTodayKey) ppCountToday++;
    else if (dk === ppYesterdayKey) ppCountYesterday++;
  });
  var ppActiveFilter = ppCountToday > 0 ? 'today' : 'all';
%>

        <!-- ===== MOBILE PLAYERS PREDICTIONS (≤860px) ===== -->
        <div class="pp">

          <!-- Header -->
          <div class="pp-header">
            <div class="pp-header-bg"></div>
            <div class="pp-header-inner">
              <div class="pp-header-logo">
                <img src="/logo.png" alt="شعار مسابقة توقعات كأس العالم 2026" style="width:90px;height:90px;object-fit:contain;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.3));">
              </div>
              <h1 class="pp-header-title">توقعات المتسابقين</h1>
              <p class="pp-header-sub">اطلع على توقعات المتسابقين للمباريات المتاحة</p>
            </div>
          </div>

          <!-- Tabs: المباريات / لعبة التحدي -->
          <div class="ms2-group-wrap" style="margin:0 0 6px;padding:0 12px;">
            <div class="ms2-group-scroll" style="display:flex;gap:6px;">
              <button class="ms-date-pill active" id="ppTabMatches" onclick="ppSwitchTab('matches',this)">⚽ توقعات المباريات</button>
              <button class="ms-date-pill" id="ppTabChallenge" onclick="ppSwitchTab('challenge',this)">🎯 لعبة التحدي</button>
            </div>
          </div>

          <!-- ===== TAB: المباريات ===== -->
          <div id="ppSectionMatches">
          <!-- Date Filters -->
          <div class="ms2-group-wrap" style="margin:0 0 10px;padding:0 12px;">
            <div class="ms2-group-scroll">
              <button class="ms-date-pill <%= ppActiveFilter==='today'?'active':'' %>" data-pp-date="today" onclick="ppDateFilter('today',this)">اليوم (<%= ppCountToday %>)</button>
              <button class="ms-date-pill <%= ppActiveFilter==='yesterday'?'active':'' %>" data-pp-date="yesterday" onclick="ppDateFilter('yesterday',this)">الأمس (<%= ppCountYesterday %>)</button>
              <button class="ms-date-pill <%= ppActiveFilter==='all'?'active':'' %>" data-pp-date="all" onclick="ppDateFilter('all',this)">الكل (<%= ppCountAll %>)</button>
            </div>
          </div>

          <!-- No matches state -->
          <% if (matchesWithPredictions.length === 0) { %>
          <div class="pp-empty-state">
            <div class="pp-empty-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
            </div>
            <h3>لا توجد مباريات متاحة لعرض التوقعات</h3>
            <p>ستظهر هنا المباريات التي تسمح الإدارة بعرض توقعاتها</p>
          </div>
          <% } else { %>

          <!-- Match List -->
          <div class="pp-list">
            <% matchesWithPredictions.forEach(function(item) {
              var m = item.match;
              var ended = m.actual_scoreA != null;
              var matchDate = new Date(m.start_at);
              var ppCardDateKey = ppDateKey(m.start_at);
              var preds = item.predictions || [];

              // Sort predictions: by accuracy desc, then points desc, then name
              preds.sort(function(a, b) {
                var accA = ppAccMap[a.user_id] || 0;
                var accB = ppAccMap[b.user_id] || 0;
                if (accB !== accA) return accB - accA;
                var ptsA = 0, ptsB = 0;
                if (leaderboard) {
                  var eA = leaderboard.find(function(e) { return e.id === a.user_id; });
                  var eB = leaderboard.find(function(e) { return e.id === b.user_id; });
                  if (eA) ptsA = eA.total || 0;
                  if (eB) ptsB = eB.total || 0;
                }
                if (ptsB !== ptsA) return ptsB - ptsA;
                return (a.user_name || '').localeCompare(b.user_name || '');
              });
            %>
              <div class="pp-card" data-pp-id="<%= m.id %>" data-pp-date="<%= ppCardDateKey %>" onclick="ppToggle(<%= m.id %>)">
              <!-- Match Info -->
              <div class="pp-card-body">
                <div class="pp-teams">
                  <div class="pp-team">
                    <img src="/flags/<%= teamFlags[m.teamA] || 'unknown' %>.png" alt="" class="pp-flag" onerror="this.src='/flags/unknown.png'">
                    <span class="pp-team-name"><%= m.teamA %></span>
                    <% if (ended) { %>
                      <span class="pp-score-badge pp-single"><%= m.actual_scoreA %></span>
                    <% } %>
                  </div>
                  <div class="pp-vs">
                    <% if (ended) { %>
                      <span class="pp-vs-dash">-</span>
                    <% } else { %>
                      <span class="pp-vs-text">VS</span>
                    <% } %>
                  </div>
                  <div class="pp-team">
                    <img src="/flags/<%= teamFlags[m.teamB] || 'unknown' %>.png" alt="" class="pp-flag" onerror="this.src='/flags/unknown.png'">
                    <span class="pp-team-name"><%= m.teamB %></span>
                    <% if (ended) { %>
                      <span class="pp-score-badge pp-single"><%= m.actual_scoreB %></span>
                    <% } %>
                  </div>
                </div>
                <div class="pp-meta">
                  <span class="pp-date"><%= matchDate.toLocaleDateString('ar-SA', { weekday:'long', month:'long', day:'numeric', timeZone:'Asia/Riyadh' }) %></span>
                  <span class="pp-time"><%= matchDate.toLocaleTimeString('ar-EG', { hour:'2-digit', minute:'2-digit', timeZone:'Asia/Riyadh' }) %></span>
                  <span class="pp-stage"><%= m.stage || '' %><% if (m.round) { %> - الجولة <%= m.round %><% } %></span>
                </div>
              </div>

              <!-- Expand Toggle -->
              <div class="pp-toggle">
                <span>عرض توقعات المتسابقين</span>
                <svg class="pp-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </div>

              <!-- Accordion Content -->
              <div class="pp-accordion">
                <% if (!approvedUsers || approvedUsers.length === 0) { %>
                  <div class="pp-no-preds">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    لا يوجد متسابقون بعد
                  </div>
                <% } else { %>
                  <div class="pp-table-wrap">
                    <div class="pp-table">
                      <div class="pp-tr pp-tr-head">
                        <span class="pp-td pp-td-rank">الترتيب</span>
                        <span class="pp-td pp-td-player">المتسابق</span>
                        <span class="pp-td pp-td-score">توقعه</span>
                        <span class="pp-td pp-td-acc">معدل الدقة</span>
                      </div>
                      <%
                        var predMap = {};
                        preds.forEach(function(p) { predMap[p.user_id] = p; });
                        var allUsers = approvedUsers || [];
                        var usersWithPred = [];
                        var usersWithoutPred = [];
                        allUsers.forEach(function(u) {
                          if (predMap[u.id]) { usersWithPred.push(u); }
                          else { usersWithoutPred.push(u); }
                        });
                        // Sort users with predictions by accuracy desc, then points desc, then name
                        usersWithPred.sort(function(a, b) {
                          var pa = predMap[a.id], pb = predMap[b.id];
                          var accA = ppAccMap[a.id] || 0;
                          var accB = ppAccMap[b.id] || 0;
                          if (accB !== accA) return accB - accA;
                          var ptsA = 0, ptsB = 0;
                          if (leaderboard) {
                            var eA = leaderboard.find(function(e) { return e.id === a.id; });
                            var eB = leaderboard.find(function(e) { return e.id === b.id; });
                            if (eA) ptsA = eA.total || 0;
                            if (eB) ptsB = eB.total || 0;
                          }
                          if (ptsB !== ptsA) return ptsB - ptsA;
                          return (a.name || '').localeCompare(b.name || '');
                        });
                        var shownUsers = usersWithPred.concat(usersWithoutPred);
                      %>
                      <% shownUsers.forEach(function(u, idx) {
                        var pred = predMap[u.id];
                        var hasPred = !!pred;
                        var userAcc = hasPred ? (ppAccMap[pred.user_id] || 0) : null;
                        var userAccLabel = userAcc != null ? userAcc + '%' : '—';
                      %>
                      <div class="pp-tr">
                        <span class="pp-td pp-td-rank">
                          <% if (idx === 0) { %><span class="pp-rank-badge pp-rank-gold">1</span>
                          <% } else if (idx === 1) { %><span class="pp-rank-badge pp-rank-silver">2</span>
                          <% } else if (idx === 2) { %><span class="pp-rank-badge pp-rank-bronze">3</span>
                          <% } else { %><span class="pp-rank-num"><%= idx + 1 %></span><% } %>
                        </span>
                        <span class="pp-td pp-td-player">
                          <span class="pp-player-avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                          </span>
                          <span class="pp-player-name"><%= u.name %></span>
                        </span>
                        <span class="pp-td pp-td-score">
                          <% if (hasPred) { %>
                          <span class="pp-score-pill">
                            <img src="/flags/<%= teamFlags[m.teamA] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.src='/flags/unknown.png'">
                            <%= pred.scoreA %>
                            <span class="pp-score-dash">-</span>
                            <%= pred.scoreB %>
                            <img src="/flags/<%= teamFlags[m.teamB] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.src='/flags/unknown.png'">
                          </span>
                          <% } else { %>
                          <span class="pp-no-pred-text">لم يسجل توقع</span>
                          <% } %>
                        </span>
                        <span class="pp-td pp-td-acc">
                          <span class="pp-acc-pill"><%= userAccLabel %></span>
                        </span>
                      </div>
                      <% }); %>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
            <% }); %>
          </div>

          <% } %>

        </div>
        <!-- ===== END MOBILE PP ===== -->

        <!-- ===== DESKTOP PP (≥861px) ===== -->
        <div class="pp-desktop">
          <header class="pp-topbar">
            <div class="pp-topbar-right">
              <h1 class="pp-topbar-title">توقعات المتسابقين 👥</h1>
              <p class="pp-topbar-subtitle">شاهد توقعات المتسابقين الآخرين للمباريات المسموح بها</p>
            </div>
          </header>

          <!-- Date Filters (desktop) -->
          <div class="pr-filters" style="margin-bottom:14px;">
            <button class="pr-filter-pill sc-date-pill <%= ppActiveFilter==='today'?'active':'' %>" data-pp-date="today" onclick="ppDateFilter('today',this)">اليوم (<%= ppCountToday %>)</button>
            <button class="pr-filter-pill sc-date-pill <%= ppActiveFilter==='yesterday'?'active':'' %>" data-pp-date="yesterday" onclick="ppDateFilter('yesterday',this)">الأمس (<%= ppCountYesterday %>)</button>
            <button class="pr-filter-pill sc-date-pill <%= ppActiveFilter==='all'?'active':'' %>" data-pp-date="all" onclick="ppDateFilter('all',this)">الكل (<%= ppCountAll %>)</button>
          </div>

          <% if (matchesWithPredictions.length === 0) { %>
            <div class="pp-empty">
              <div class="pp-empty-icon">👀</div>
              <div class="pp-empty-title">لا توجد توقعات متاحة</div>
              <div class="pp-empty-text">لم يقم المدير بإظهار أي توقعات بعد.</div>
            </div>
          <% } else { %>
            <% matchesWithPredictions.forEach(function(item) { %>
              <div class="pp-match-card" data-pp-date="<%= ppDateKey(item.match.start_at) %>">
                    <div class="pp-match-header">
                  <div class="pp-match-teams">
                    <div class="pp-match-team">
                      <div class="pp-match-flag"><img src="/flags/<%= teamFlags[item.match.teamA] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'"></div>
                      <span class="pp-match-name"><%= item.match.teamA %></span>
                      <% if (item.match.actual_scoreA != null) { %>
                        <span class="pp-final-score pp-single-desktop"><%= item.match.actual_scoreA %></span>
                      <% } %>
                    </div>
                    <div class="pp-vs">
                      <% if (item.match.actual_scoreA != null) { %>
                        <span class="pp-dash-desktop">-</span>
                      <% } else { %>VS<% } %>
                    </div>
                    <div class="pp-match-team">
                      <span class="pp-match-name"><%= item.match.teamB %></span>
                      <div class="pp-match-flag"><img src="/flags/<%= teamFlags[item.match.teamB] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'"></div>
                      <% if (item.match.actual_scoreA != null) { %>
                        <span class="pp-final-score pp-single-desktop"><%= item.match.actual_scoreB %></span>
                      <% } %>
                    </div>
                  </div>
                  <div class="pp-match-meta">
                    <span class="pp-group-badge"><%= item.match.stage %></span>
                    <span class="pp-match-time">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <%= new Date(item.match.start_at).toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Riyadh' }) %>
                    </span>
                    <span class="pp-preds-count"><%= (approvedUsers || []).length %> متسابق</span>
                  </div>
                </div>
                <%
                  var deskPredMap = {};
                  (item.predictions || []).forEach(function(p) { deskPredMap[p.user_id] = p; });
                  var deskUsers = approvedUsers || [];
                  var deskShown = [];
                  deskUsers.forEach(function(u) {
                    if (deskPredMap[u.id]) { deskShown.push(u); }
                  });
                  deskUsers.forEach(function(u) {
                    if (!deskPredMap[u.id]) { deskShown.push(u); }
                  });
                %>
                <% if (deskShown.length > 0) { %>
                <div class="pp-preds-list">
                  <% deskShown.forEach(function(u) {
                    var dp = deskPredMap[u.id];
                    var hasDp = !!dp;
                  %>
                  <div class="pp-pred-row">
                    <div class="pp-pred-avatar pp-avatar-color-<%= (u.id % 6) + 1 %>">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                    </div>
                    <span class="pp-pred-name"><%= u.name %></span>
                    <div class="pp-pred-divider"></div>
                    <% if (hasDp) { %>
                    <img class="pp-pred-flag" src="/flags/<%= teamFlags[item.match.teamA] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'">
                    <span class="pp-pred-team-name"><%= item.match.teamA %></span>
                    <div class="pp-pred-score">
                      <span class="pp-pred-num"><%= dp.scoreA %></span>
                      <span class="pp-pred-sep">-</span>
                      <span class="pp-pred-num"><%= dp.scoreB %></span>
                    </div>
                    <span class="pp-pred-team-name"><%= item.match.teamB %></span>
                    <img class="pp-pred-flag" src="/flags/<%= teamFlags[item.match.teamB] || 'unknown' %>.png" alt="" onerror="this.src='/flags/unknown.png'">
                    <% if (item.match.actual_scoreA != null) { %>
                      <div class="pp-pred-result">
                        <% if (dp.scoreA === item.match.actual_scoreA && dp.scoreB === item.match.actual_scoreB) { %>
                          <span class="pp-result-exact">✓</span>
                        <% } else if ((dp.scoreA > dp.scoreB && item.match.actual_scoreA > item.match.actual_scoreB) || (dp.scoreA < dp.scoreB && item.match.actual_scoreA < item.match.actual_scoreB) || (dp.scoreA === dp.scoreB && item.match.actual_scoreA === item.match.actual_scoreB)) { %>
                          <span class="pp-result-correct">✓</span>
                        <% } else { %>
                          <span class="pp-result-wrong">✗</span>
                        <% } %>
                      </div>
                    <% } %>
                    <% } else { %>
                    <span class="pp-pred-no-score">لم يسجل توقع</span>
                    <% } %>
                  </div>
                  <% }); %>
                </div>
                <% } else { %>
                  <div class="pp-no-preds">لا يوجد متسابقون بعد</div>
                <% } %>
          </div>

        <% } %>
        </div>
        </div><!-- end ppSectionMatches -->

        <!-- ===== TAB: لعبة التحدي ===== -->
        <div id="ppSectionChallenge" style="display:none;">

          <!-- Stats Cards -->
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;margin-bottom:16px;padding:0 12px;">
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;text-align:center;">
              <div style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">إجمالي المشاركين</div>
              <div style="font-size:1.4rem;font-weight:900;color:var(--text);margin-top:2px;"><%= challengePicks.length %></div>
            </div>
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;text-align:center;">
              <div style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">منتخب في دور الـ8</div>
              <div style="font-size:1.4rem;font-weight:900;color:var(--text);margin-top:2px;"><%= challengeStats.qf.length %></div>
            </div>
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;text-align:center;">
              <div style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">منتخب في دور الـ4</div>
              <div style="font-size:1.4rem;font-weight:900;color:var(--text);margin-top:2px;"><%= challengeStats.sf.length %></div>
            </div>
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;text-align:center;">
              <div style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">منتخب في النهائي</div>
              <div style="font-size:1.4rem;font-weight:900;color:var(--text);margin-top:2px;"><%= challengeStats.finalists.length %></div>
            </div>
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;text-align:center;">
              <div style="font-size:0.72rem;color:var(--text-secondary);font-weight:700;">مرشح للبطل</div>
              <div style="font-size:1.4rem;font-weight:900;color:var(--text);margin-top:2px;"><%= challengeStats.champion.length %></div>
            </div>
          </div>

          <!-- Champion Stats -->
          <div style="padding:0 12px;margin-bottom:16px;">
            <div style="font-weight:800;font-size:0.9rem;margin-bottom:8px;">🏆 توقعات البطل</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% challengeStats.champion.forEach(function(entry) { %>
              <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;font-size:0.82rem;font-weight:600;">
                <img src="/flags/<%= teamFlags[entry[0]] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.style.display='none'">
                <span><%= entry[0] %></span>
                <span style="background:rgba(212,175,55,0.15);color:#d4af37;padding:1px 8px;border-radius:10px;font-size:0.72rem;font-weight:800;"><%= entry[1] %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Finalists Stats -->
          <div style="padding:0 12px;margin-bottom:16px;">
            <div style="font-weight:800;font-size:0.9rem;margin-bottom:8px;">🎯 توقعات طرفي النهائي</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% challengeStats.finalists.forEach(function(entry) { %>
              <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;font-size:0.82rem;font-weight:600;">
                <img src="/flags/<%= teamFlags[entry[0]] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.style.display='none'">
                <span><%= entry[0] %></span>
                <span style="background:rgba(99,102,241,0.12);color:var(--primary);padding:1px 8px;border-radius:10px;font-size:0.72rem;font-weight:800;"><%= entry[1] %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- SF Stats -->
          <div style="padding:0 12px;margin-bottom:16px;">
            <div style="font-weight:800;font-size:0.9rem;margin-bottom:8px;">📊 توقعات دور الـ4</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% challengeStats.sf.forEach(function(entry) { %>
              <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;font-size:0.82rem;font-weight:600;">
                <img src="/flags/<%= teamFlags[entry[0]] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.style.display='none'">
                <span><%= entry[0] %></span>
                <span style="background:rgba(34,197,94,0.12);color:#22c55e;padding:1px 8px;border-radius:10px;font-size:0.72rem;font-weight:800;"><%= entry[1] %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- QF Stats -->
          <div style="padding:0 12px;margin-bottom:16px;">
            <div style="font-weight:800;font-size:0.9rem;margin-bottom:8px;">📊 توقعات دور الـ8</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% challengeStats.qf.forEach(function(entry) { %>
              <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;font-size:0.82rem;font-weight:600;">
                <img src="/flags/<%= teamFlags[entry[0]] || 'unknown' %>.png" class="pp-mini-flag" onerror="this.style.display='none'">
                <span><%= entry[0] %></span>
                <span style="background:rgba(245,158,11,0.12);color:#d97706;padding:1px 8px;border-radius:10px;font-size:0.72rem;font-weight:800;"><%= entry[1] %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Participants Picks (accordion) -->
          <div style="padding:0 12px;">
            <div style="font-weight:800;font-size:0.9rem;margin-bottom:8px;">اختيارات المتسابقين</div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <% challengePicks.forEach(function(p) { %>
              <div class="db-pred-match">
                <div class="db-pred-match-header" onclick="this.parentElement.classList.toggle('open')">
                  <div class="db-pred-match-title" style="font-size:0.85rem;">
                    <span style="font-weight:800;"><%= p.user_name %></span>
                  </div>
                  <div class="db-pred-match-right">
                    <span class="db-pred-chevron">▼</span>
                  </div>
                </div>
                <div class="db-pred-body" style="padding:12px 14px;">
                  <% if (p.qf && Array.isArray(p.qf)) { %>
                  <div style="margin-bottom:8px;">
                    <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">دور الـ8:</div>
                    <div style="display:flex;flex-wrap:wrap;gap:4px;">
                      <% p.qf.forEach(function(t) { %>
                      <span style="padding:2px 8px;background:rgba(212,175,55,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>
                  <% if (p.sf && Array.isArray(p.sf)) { %>
                  <div style="margin-bottom:8px;">
                    <div style="font-size:0.75rem;font-weight:700;color:var(--primary);margin-bottom:4px;">دور الـ4:</div>
                    <div style="display:flex;flex-wrap:wrap;gap:4px;">
                      <% p.sf.forEach(function(t) { %>
                      <span style="padding:2px 8px;background:rgba(99,102,241,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>
                  <% if (p.finalists && Array.isArray(p.finalists)) { %>
                  <div style="margin-bottom:8px;">
                    <div style="font-size:0.75rem;font-weight:700;color:#22c55e;margin-bottom:4px;">طرفا النهائي:</div>
                    <div style="display:flex;flex-wrap:wrap;gap:4px;">
                      <% p.finalists.forEach(function(t) { %>
                      <span style="padding:2px 8px;background:rgba(34,197,94,0.1);border-radius:6px;font-size:0.78rem;font-weight:600;"><%= t %></span>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>
                  <% if (p.champion) { %>
                  <div>
                    <div style="font-size:0.75rem;font-weight:700;color:#d4af37;margin-bottom:4px;">البطل:</div>
                    <span style="padding:2px 10px;background:rgba(212,175,55,0.15);border-radius:6px;font-size:0.82rem;font-weight:800;color:#d4af37;"><%= p.champion %></span>
                  </div>
                  <% } %>
                </div>
              </div>
              <% }) %>
            </div>
          </div>

        </div><!-- end ppSectionChallenge -->

      </section>
    </main>
  </div>

  <script>
    function ppSwitchTab(tab, btn) {
      document.querySelectorAll('#ppTabMatches, #ppTabChallenge').forEach(function(b){ b.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      document.getElementById('ppSectionMatches').style.display = tab === 'matches' ? '' : 'none';
      document.getElementById('ppSectionChallenge').style.display = tab === 'challenge' ? '' : 'none';
    }

    function ppDateKey(d) {
      if (!d) return '';
      try { return new Date(d).toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' }); } catch(e) { return ''; }
    }
    function ppGetTodayKey() {
      return new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
    }
    function ppGetYesterdayKey() {
      var d = new Date(); d.setDate(d.getDate() - 1);
      return d.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
    }
    function ppDateFilter(filter, btn) {
      // Update pills in both mobile and desktop
      document.querySelectorAll('[data-pp-date]').forEach(function(b){ b.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      // Same-date pills might be in both sections; sync them
      document.querySelectorAll('[data-pp-date="' + filter + '"]').forEach(function(b){ b.classList.add('active'); });
      var targetKey;
      if (filter === 'today') targetKey = ppGetTodayKey();
      else if (filter === 'yesterday') targetKey = ppGetYesterdayKey();
      // Filter mobile cards
      document.querySelectorAll('.pp-card[data-pp-date]').forEach(function(card){
        if (filter === 'all') { card.style.display = ''; }
        else { card.style.display = (card.getAttribute('data-pp-date') === targetKey) ? '' : 'none'; }
      });
      // Filter desktop cards
      document.querySelectorAll('.pp-match-card[data-pp-date]').forEach(function(card){
        if (filter === 'all') { card.style.display = ''; }
        else { card.style.display = (card.getAttribute('data-pp-date') === targetKey) ? '' : 'none'; }
      });
      // Show/hide empty messages
      var visibleMobile = document.querySelectorAll('.pp-card[data-pp-date]:not([style*=\"display: none\"])');
      var visibleDesktop = document.querySelectorAll('.pp-match-card[data-pp-date]:not([style*=\"display: none\"])');
      var existingMsg = document.getElementById('ppFilterEmpty');
      if (visibleMobile.length === 0 && visibleDesktop.length === 0) {
        if (!existingMsg) {
          var msg = document.createElement('div');
          msg.id = 'ppFilterEmpty';
          msg.className = 'pp-empty-state';
          msg.style.cssText = 'text-align:center;padding:30px 16px;';
          msg.innerHTML = '<div class="pp-empty-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg></div><h3 style="margin:8px 0 4px;font-size:1rem;">لا توجد مباريات في هذا اليوم</h3>';
          var mobileContainer = document.querySelector('.pp-list');
          if (mobileContainer) mobileContainer.appendChild(msg);
        } else { existingMsg.style.display = ''; }
      } else {
        if (existingMsg) existingMsg.style.display = 'none';
      }
    }
    // Initialize filter on page load
    (function(){
      var activePill = document.querySelector('[data-pp-date].active');
      if (activePill) {
        ppDateFilter(activePill.getAttribute('data-pp-date'), activePill);
      }
    })();

    var ppOpenId = null;
    function ppToggle(id) {
      var card = document.querySelector('.pp-card[data-pp-id="' + id + '"]');
      if (!card) return;
      if (ppOpenId === id) {
        card.classList.remove('pp-is-open');
        ppOpenId = null;
      } else {
        if (ppOpenId) {
          var prev = document.querySelector('.pp-card[data-pp-id="' + ppOpenId + '"]');
          if (prev) prev.classList.remove('pp-is-open');
        }
        card.classList.add('pp-is-open');
        ppOpenId = id;
      }
    }
  </script>
<%- include('partials/mobile-nav', { active: 'players-predictions' }) %>
</body>
</html>
