<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>خطأ - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <% var _errUser = typeof user !== 'undefined' ? user : null; %>
    <%- include('partials/sidebar', { active: null, user: _errUser, top3: [] }) %>
    <main class="main-content">
      <section class="page-content" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;">
        <div style="font-size:5rem;margin-bottom:20px;">⚠️</div>
        <h1 style="font-size:2rem;margin-bottom:12px;">حدث خطأ</h1>
        <p style="font-size:1.1rem;color:var(--text-secondary);max-width:400px;line-height:1.8;"><%= typeof message !== 'undefined' ? message : 'الصفحة التي تبحث عنها غير موجودة أو حدث خطأ غير متوقع' %></p>
        <a href="/home" style="display:inline-flex;align-items:center;gap:8px;margin-top:24px;padding:14px 28px;border-radius:14px;background:var(--primary);color:#fff;text-decoration:none;font-weight:700;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          العودة للرئيسية
        </a>
      </section>
    </main>
  </div>
  <%- include('partials/mobile-nav', { active: null, user: _errUser }) %>
</body>
</html>